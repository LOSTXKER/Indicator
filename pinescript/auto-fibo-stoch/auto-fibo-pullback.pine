//@version=6
indicator("auto-fibo-pullback V.3", overlay = true, max_lines_count = 500, max_labels_count = 500)

// ─────────────────────────────────────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────────────────────────────────────

// ── 🎯 Fibo เป้า (Target) ──────────────────────────────────────────────────
grpTarget  = "🎯 Fibo เป้า (Target)"
i_dayTarget  = input.bool(false, "Day",  inline = "tDay", group = grpTarget)
i_dayPending = input.bool(false, "Pending", inline = "tDay", group = grpTarget)
i_h4Target   = input.bool(true,  "H4",   inline = "tH4",  group = grpTarget)
i_h4Pending  = input.bool(true,  "Pending", inline = "tH4",  group = grpTarget)
i_h1Target   = input.bool(true,  "H1",   inline = "tH1",  group = grpTarget)
i_h1Pending  = input.bool(true,  "Pending", inline = "tH1",  group = grpTarget)
i_m15Target  = input.bool(false, "M15",  inline = "tM15", group = grpTarget)
i_m15Pending = input.bool(false, "Pending", inline = "tM15", group = grpTarget)
i_m5Target   = input.bool(false, "M5",   inline = "tM5",  group = grpTarget)
i_m5Pending  = input.bool(false, "Pending", inline = "tM5",  group = grpTarget)
i_m1Target   = input.bool(false, "M1",   inline = "tM1",  group = grpTarget)
i_m1Pending  = input.bool(false, "Pending", inline = "tM1",  group = grpTarget)
i_showHK     = input.bool(true, "แสดง HK",  inline = "tType", group = grpTarget)
i_showSB     = input.bool(true, "แสดง SB",  inline = "tType", group = grpTarget)
i_maxSets    = input.int(5, "ชุดสูงสุด (ต่อทิศทาง)", minval = 1, maxval = 5, group = grpTarget)

// ── 🔰 Fibo จุดเข้า (Entry) ───────────────────────────────────────────────
grpEntry   = "🔰 Fibo จุดเข้า (Entry)"
i_dayEntry   = input.bool(false, "Day",  group = grpEntry)
i_h4Entry    = input.bool(false, "H4",   group = grpEntry)
i_h1Entry    = input.bool(false, "H1",   group = grpEntry)
i_m15Entry   = input.bool(false, "M15",  group = grpEntry)
i_m5Entry    = input.bool(false, "M5",   group = grpEntry)
i_m1Entry    = input.bool(false, "M1",   group = grpEntry)
i_maxSupSets = input.int(5, "ชุดสูงสุด (ต่อทิศทาง)", minval = 1, maxval = 5, group = grpEntry)

// ── ⚙️ Stochastic ─────────────────────────────────────────────────────────
grpCore    = "⚙️ Stochastic"
i_kPeriod  = input.int(9,   "K Period",  minval = 1,  group = grpCore)
i_slowing  = input.int(3,   "Slowing",   minval = 1,  group = grpCore)
i_ovsLevel = input.int(20,  "OVS Level", minval = 1,  maxval = 49, group = grpCore)
i_ovbLevel = input.int(80,  "OVB Level", minval = 51, maxval = 99, group = grpCore)

// ── 📍 RSI Cut ────────────────────────────────────────────────────────────
grpRsiCut    = "📍 RSI Cut"
i_rsiCutEnabled = input.bool(true,  "เปิดใช้ RSI Cut",  group = grpRsiCut)
i_rsiPeriod     = input.int(14,     "RSI Period",       minval = 1, group = grpRsiCut)
i_rsiOvsLevel   = input.int(30,     "RSI OVS Level",    minval = 1,  maxval = 49, group = grpRsiCut)
i_rsiOvbLevel   = input.int(70,     "RSI OVB Level",    minval = 51, maxval = 99, group = grpRsiCut)

// ── 📍 EMA ────────────────────────────────────────────────────────────────
grpEMA     = "📍 EMA"
i_emaFast  = input.int(14, "Fast EMA",  minval = 1, group = grpEMA)
i_emaSlow  = input.int(60, "Slow EMA",  minval = 1, group = grpEMA)
i_showEMA  = input.bool(true, "แสดงเส้น EMA", group = grpEMA)
i_showEMAbg = input.bool(true, "แสดงพื้นหลัง EMA Cross", group = grpEMA)

// ── 📍 H4 EMA (เฉพาะ H1) ───────────────────────────────────────────────
grpH4EMA      = "📍 H4 EMA (เฉพาะ H1)"
i_showHTF_EMA = input.bool(true, "แสดง H4 EMA", group = grpH4EMA)
i_htfEMA_Len  = input.int(60, "Length", minval = 1, group = grpH4EMA)
i_htfEMA_Col  = input.color(#FFFFFF, "Color", group = grpH4EMA)

// ── 📊 แสดงผล ─────────────────────────────────────────────────────────────
grpDisplay = "📊 แสดงผล"
i_showMarkers = input.bool(true,  "แสดงจุด OVS/OVB",      group = grpDisplay)
i_maxMarkers  = input.int(30, "จำนวนจุดสูงสุด (คู่)",    minval = 5, maxval = 100, group = grpDisplay)
i_showTrend   = input.bool(true, "แสดงป้ายเทรน (UP/DN)",  group = grpDisplay)
i_showZones   = input.bool(false, "แสดงพื้นหลังโซน OVS/OVB", group = grpDisplay)
i_debugStoch  = input.bool(false, "🔧 Debug: แสดง K value ที่จุด finalize", group = grpDisplay)

// ── 🕯️ Momentum Candle ─────────────────────────────────────────────────────
grpMom       = "🕯️ Momentum Candle"
i_showMom    = input.bool(true,  "ระบายสีแท่ง",            group = grpMom)
i_momDay     = input.bool(false, "Day",  inline = "mTF1", group = grpMom)
i_momH4      = input.bool(false, "H4",   inline = "mTF1", group = grpMom)
i_momH1      = input.bool(false, "H1",   inline = "mTF1", group = grpMom)
i_momM15     = input.bool(true,  "M15",  inline = "mTF2", group = grpMom)
i_momM5      = input.bool(true,  "M5",   inline = "mTF2", group = grpMom)
i_momM3      = input.bool(true,  "M3",   inline = "mTF2", group = grpMom)
i_momM1      = input.bool(true,  "M1",   inline = "mTF2", group = grpMom)
i_momMult    = input.float(1.5,  "Super Body Multiplier", minval = 1.0, step = 0.1, group = grpMom)
i_momLen     = input.int(15,     "Average Length",         minval = 1,   group = grpMom)
i_momVolFilt = input.bool(true,  "Volume Filter",         group = grpMom)
i_momVolMult = input.float(1.0,  "Volume Multiplier",     minval = 0.5, step = 0.1, group = grpMom)
i_momVolLen  = input.int(20,     "Volume Avg Length",      minval = 1,   group = grpMom)

// ── 🎨 สี ─────────────────────────────────────────────────────────────────
grpColors  = "🎨 สี"
i_dayCol     = input.color(color.new(#AB47BC, 10), "Day",  inline = "cTF1", group = grpColors)
i_h4Col      = input.color(color.new(#26C6DA, 10), "H4",   inline = "cTF1", group = grpColors)
i_h1Col      = input.color(color.new(#66BB6A, 10), "H1",   inline = "cTF1", group = grpColors)
i_m15Col     = input.color(color.new(#FFA726, 10), "M15",  inline = "cTF2", group = grpColors)
i_m5Col      = input.color(color.new(#E040FB, 10), "M5",   inline = "cTF2", group = grpColors)
i_m1Col      = input.color(color.new(#80CBC4, 10), "M1",   inline = "cTF2", group = grpColors)
i_colPending  = input.color(color.new(#EF5350, 10), "Pending",   inline = "cSpec", group = grpColors)
i_colHL       = input.color(color.new(#00E676,  0), "Highlight", inline = "cSpec", group = grpColors)

// ─────────────────────────────────────────────────────────────────────────────
// Constants
// ─────────────────────────────────────────────────────────────────────────────

var int SM_WAIT_OVS = 0
var int SM_WAIT_OVB = 1

var int ST_PENDING = 0
var int ST_VALID   = 1

var int FT_HAK_KHO = 0
var int FT_SOMBOON = 1

var float[] FIBO_LEVELS = array.from(1.618, 2.0, 2.618, 4.236)
var string[] FIBO_LABELS = array.from("161.8", "200", "261.8", "423.6")

var float[] SUP_FIBO_LEVELS = array.from(0.382, 0.5, 0.618)
var string[] SUP_FIBO_LABELS = array.from("38.2", "50", "61.8")

// ─────────────────────────────────────────────────────────────────────────────
// UDT: FiboSet
// ─────────────────────────────────────────────────────────────────────────────

type FiboSet
    float   ovs_low
    float   ovb_high
    int     status
    int     fiboType
    int     fDir
    int     hlIdx = -1
    line[]  ln
    label[] lb
    line    diagLn = na
    label   bannerLb = na

// ─────────────────────────────────────────────────────────────────────────────
// UDT: TFEngine
// ─────────────────────────────────────────────────────────────────────────────

type TFEngine
    int     sm = 0
    float   ovsLo = na
    int     ovsLoT = na
    float   ovbHi = na
    int     ovbHiT = na
    float   confOvbHi = na
    int     confOvbHiT = na
    float   prevOvsLo = na
    int     prevOvsLoT = na
    float   prevOvbHi = na
    int     prevOvbHiT = na
    int     trend = 0
    bool    canDrawUp = true
    bool    canDrawDn = true
    string  tfTag = ""
    color   col
    bool    showTarget = true
    bool    showEntry = true
    bool    showPending = true
    FiboSet[] targetSets
    FiboSet[] entrySets
    int     prevBarT = na
    float   cacheK = na
    float   cacheH = na
    float   cacheL = na
    float   cacheC = na
    // Chart-TF visual state (เฉพาะ engine ที่ตรงกับ chart TF เท่านั้นที่ใช้)
    label   curOvsLbl = na
    label   curOvbLbl = na
    // Deferred confirmation: marker ยัง unconfirmed จนกว่าจะเจอตัวถัดไปของ type เดียวกัน
    label   unconfOvsLbl = na
    label   unconfOvbLbl = na
    // OVS marker ที่ finalize แล้วแต่ยังขยับได้ใน SM_WAIT_OVB (option C: capture wick ที่ต่ำกว่า)
    label   lockedOvsLbl = na
    float   lockedOvsLo  = na
    int     lockedOvsLoT = na
    // OVB marker ที่ finalize แล้วแต่ยังขยับได้ใน SM_WAIT_OVS (capture wick ที่สูงกว่า)
    label   lockedOvbLbl = na
    float   lockedOvbHi  = na
    int     lockedOvbHiT = na
    // ติดตาม lowest low ระหว่าง peak เก่า → peak ใหม่ (commit ตอนเจอ peak ใหม่ เพื่อรักษา alternation)
    float   lowSincePeak  = na
    int     lowSincePeakT = na
    // ติดตาม highest high ระหว่าง valley เก่า → valley ใหม่ (commit ตอนเจอ valley ใหม่)
    float   highSinceValley  = na
    int     highSinceValleyT = na
    label[] markers
    label[] trendLabels

// ─────────────────────────────────────────────────────────────────────────────
// Stochastic + RSI (chart TF)
// ─────────────────────────────────────────────────────────────────────────────

kRaw = ta.stoch(close, high, low, i_kPeriod)
kVal = ta.sma(kRaw, i_slowing)

inOvs = kVal < i_ovsLevel
inOvb = kVal > i_ovbLevel

rsiRaw = ta.rsi(close, i_rsiPeriod)
rsiInOvs = rsiRaw < i_rsiOvsLevel
rsiInOvb = rsiRaw > i_rsiOvbLevel

// ─────────────────────────────────────────────────────────────────────────────
// Momentum Candle
// ─────────────────────────────────────────────────────────────────────────────

momBody    = math.abs(close - open)
momAvg     = ta.sma(momBody, i_momLen)
momVolAvg  = ta.sma(volume, i_momVolLen)
momVolOk   = not i_momVolFilt or volume > momVolAvg * i_momVolMult
momBull    = close > open
momBear    = close < open
momSupBull = momBody > momAvg * i_momMult and momBull and momVolOk
momSupBear = momBody > momAvg * i_momMult and momBear and momVolOk
momAbvBull = momBody > momAvg and momBull and not momSupBull and momVolOk
momAbvBear = momBody > momAvg and momBear and not momSupBear and momVolOk
momState   = momSupBull ? 2 : momSupBear ? -2 : momAbvBull ? 1 : momAbvBear ? -1 : 0

momState_day = i_momDay ? request.security(syminfo.tickerid, "D",   momState) : 0
momState_h4  = i_momH4  ? request.security(syminfo.tickerid, "240", momState) : 0
momState_h1  = i_momH1  ? request.security(syminfo.tickerid, "60",  momState) : 0
momState_m15 = i_momM15 ? request.security(syminfo.tickerid, "15",  momState) : 0
momState_m5  = i_momM5  ? request.security(syminfo.tickerid, "5",   momState) : 0
momState_m3  = i_momM3  ? request.security(syminfo.tickerid, "3",   momState) : 0
momState_m1  = i_momM1  ? request.security(syminfo.tickerid, "1",   momState) : 0

_momSec     = timeframe.in_seconds()
momTFActive = (i_momDay and _momSec == timeframe.in_seconds("D"))   or
              (i_momH4  and _momSec == timeframe.in_seconds("240")) or
              (i_momH1  and _momSec == timeframe.in_seconds("60"))  or
              (i_momM15 and _momSec == timeframe.in_seconds("15"))  or
              (i_momM5  and _momSec == timeframe.in_seconds("5"))   or
              (i_momM3  and _momSec == timeframe.in_seconds("3"))   or
              (i_momM1  and _momSec == timeframe.in_seconds("1"))

momBarCol = momSupBull ? color.rgb(0, 230, 64) : momSupBear ? color.rgb(255, 23, 23) : momAbvBull ? color.rgb(0, 230, 64, 50) : momAbvBear ? color.rgb(255, 23, 23, 50) : na
barcolor(i_showMom and momTFActive ? momBarCol : na, title = "Momentum Candle")

// ─────────────────────────────────────────────────────────────────────────────
// TF Helpers
// ─────────────────────────────────────────────────────────────────────────────

formatTF(string tf) =>
    result = switch tf
        "1"    => "M1"
        "3"    => "M3"
        "5"    => "M5"
        "15"   => "M15"
        "30"   => "M30"
        "45"   => "M45"
        "60"   => "H1"
        "120"  => "H2"
        "180"  => "H3"
        "240"  => "H4"
        "D"    => "Day"
        "1D"   => "Day"
        "W"    => "Week"
        "1W"   => "Week"
        "M"    => "Month"
        "1M"   => "Month"
        => tf
    result

// ─────────────────────────────────────────────────────────────────────────────
// Multi-TF Data Fetching (ใช้ kVal ที่คำนวณครั้งเดียวแทนการ inline stoch ซ้ำ)
// ─────────────────────────────────────────────────────────────────────────────

[rsK_d,  rsH_d,  rsL_d,  rsC_d,  rsT_d]   = request.security(syminfo.tickerid, "D",   [kVal, high, low, close, time])
[rsK_4h, rsH_4h, rsL_4h, rsC_4h, rsT_4h]  = request.security(syminfo.tickerid, "240", [kVal, high, low, close, time])
[rsK_1h, rsH_1h, rsL_1h, rsC_1h, rsT_1h]  = request.security(syminfo.tickerid, "60",  [kVal, high, low, close, time])
[rsK_15, rsH_15, rsL_15, rsC_15, rsT_15]  = request.security(syminfo.tickerid, "15",  [kVal, high, low, close, time])
[rsK_5,  rsH_5,  rsL_5,  rsC_5,  rsT_5]   = request.security(syminfo.tickerid, "5",   [kVal, high, low, close, time])
[rsK_1m, rsH_1m, rsL_1m, rsC_1m, rsT_1m]  = request.security(syminfo.tickerid, "1",   [kVal, high, low, close, time])

[ltH_d,  ltL_d,  ltC_d,  ltK_d,  ltT_d]   = request.security_lower_tf(syminfo.tickerid, "D",   [high, low, close, kVal, time], ignore_invalid_timeframe = true)
[ltH_4h, ltL_4h, ltC_4h, ltK_4h, ltT_4h]  = request.security_lower_tf(syminfo.tickerid, "240", [high, low, close, kVal, time], ignore_invalid_timeframe = true)
[ltH_1h, ltL_1h, ltC_1h, ltK_1h, ltT_1h]  = request.security_lower_tf(syminfo.tickerid, "60",  [high, low, close, kVal, time], ignore_invalid_timeframe = true)
[ltH_15, ltL_15, ltC_15, ltK_15, ltT_15]  = request.security_lower_tf(syminfo.tickerid, "15",  [high, low, close, kVal, time], ignore_invalid_timeframe = true)
[ltH_5,  ltL_5,  ltC_5,  ltK_5,  ltT_5]   = request.security_lower_tf(syminfo.tickerid, "5",   [high, low, close, kVal, time], ignore_invalid_timeframe = true)
[ltH_1m, ltL_1m, ltC_1m, ltK_1m, ltT_1m]  = request.security_lower_tf(syminfo.tickerid, "1",   [high, low, close, kVal, time], ignore_invalid_timeframe = true)

// ─────────────────────────────────────────────────────────────────────────────
// Trend Transition Helpers (ตาราง transition ครบทุกเคสสำหรับทั้ง 2 ฝั่ง)
// ─────────────────────────────────────────────────────────────────────────────

trendAfterOvs(int cur, bool isHL, bool isLL) =>
    cur == 0  and isHL ? 2  :
     cur == 0  and isLL ? -1 :
     cur == -1 and isHL ? 2  :
     cur == 1  and isLL ? -2 :
     cur == -2 and isLL ? -1 :
     cur == -2 and isHL ? 1  :
     cur

trendAfterOvb(int cur, bool isHH, bool isLH) =>
    cur == 1  and isLH ? -2 :
     cur == -1 and isHH ? 2  :
     cur == 2  and isHH ? 1  :
     cur == 2  and isLH ? -1 :
     cur == -2 and isLH ? -1 :
     cur == -2 and isHH ? 1  :
     cur

// ─────────────────────────────────────────────────────────────────────────────
// Fibo Helper Functions
// ─────────────────────────────────────────────────────────────────────────────

createFiboSet(float lo, float hi, int startX, int endX, int fType, string fName, int dir, string tfTag, string xlMode, bool showPend) =>
    fs = FiboSet.new()
    fs.ovs_low  := lo
    fs.ovb_high := hi
    fs.status   := ST_PENDING
    fs.fiboType := fType
    fs.fDir     := dir
    fs.ln := array.new<line>()
    fs.lb := array.new<label>()

    rng = hi - lo
    x1  = startX
    x2  = endX

    baseCol  = i_colPending
    hlIndex  = 0
    fs.hlIdx := hlIndex

    dirTag  = dir == 1 ? "▲" : "▼"
    nameTag = fName + " เป้า" + dirTag + " " + tfTag

    pendAlpha = showPend ? 50 : 100

    for i = 0 to array.size(FIBO_LEVELS) - 1
        lvl   = array.get(FIBO_LEVELS, i)
        price = dir == 1 ? lo + lvl * rng : hi - lvl * rng
        lbl   = array.get(FIBO_LABELS, i)
        pTxt  = str.tostring(price, format.mintick)

        isRound  = i == 1

        txt  = lbl + " (" + pTxt + ")"
        lSty = isRound ? line.style_solid : line.style_dashed
        lSz  = size.small
        lAlpha = showPend ? pendAlpha : 100
        lCol = color.new(baseCol, lAlpha)

        newLine  = line.new(x1, price, x2, price, color = lCol, width = 1, style = lSty, xloc = xlMode)
        newLabel = label.new(x2, price, txt,
             style = label.style_label_left, color = color.new(color.black, 100),
             textcolor = lCol, size = lSz, xloc = xlMode)

        array.push(fs.ln, newLine)
        array.push(fs.lb, newLabel)

    if dir == 1
        fs.diagLn := line.new(x1, hi, x2, lo, color = color.new(baseCol, pendAlpha), width = 1, style = line.style_dashed, xloc = xlMode)
    else
        fs.diagLn := line.new(x1, lo, x2, hi, color = color.new(baseCol, pendAlpha), width = 1, style = line.style_dashed, xloc = xlMode)

    _banAlpha = showPend ? 70 : 100
    _banTxtCol = showPend ? i_colPending : color.new(i_colPending, 100)
    fs.bannerLb := label.new(x2, hi, "⏳ " + nameTag,
         style = label.style_label_lower_left, color = color.new(i_colPending, _banAlpha),
         textcolor = _banTxtCol, size = size.normal, xloc = xlMode)

    fs

deleteFiboSet(FiboSet fs) =>
    for i = 0 to array.size(fs.ln) - 1
        line.delete(array.get(fs.ln, i))
        label.delete(array.get(fs.lb, i))
    line.delete(fs.diagLn)
    label.delete(fs.bannerLb)

trimFiboSets(FiboSet[] sets, int dir, int maxCount) =>
    _cnt = 0
    if array.size(sets) > 0
        for i = 0 to array.size(sets) - 1
            if array.get(sets, i).fDir == dir
                _cnt += 1
    while _cnt > maxCount and array.size(sets) > 0
        _removed = false
        for i = 0 to array.size(sets) - 1
            if array.get(sets, i).fDir == dir
                deleteFiboSet(array.get(sets, i))
                array.remove(sets, i)
                _cnt -= 1
                _removed := true
                break
        if not _removed
            break

expirePendingFibos(FiboSet[] sets, int dir) =>
    _exp = array.new<int>()
    if array.size(sets) > 0
        for i = 0 to array.size(sets) - 1
            _fs = array.get(sets, i)
            if _fs.status == ST_PENDING and _fs.fDir == dir
                deleteFiboSet(_fs)
                array.push(_exp, i)
        if array.size(_exp) > 0
            for jj = array.size(_exp) - 1 to 0
                array.remove(sets, array.get(_exp, jj))
    array.size(_exp)

confirmFiboSet(FiboSet fs, color col) =>
    lvlCount = array.size(fs.ln)
    for i = 0 to lvlCount - 1
        l = array.get(fs.ln, i)
        lb = array.get(fs.lb, i)
        isHL     = i == fs.hlIdx
        isRound  = i == 1

        lCol = isHL ? i_colHL : col
        lW   = 2
        lSty = isRound ? line.style_solid : line.style_dashed
        lSz  = size.small

        line.set_color(l, lCol)
        line.set_width(l, lW)
        line.set_style(l, lSty)
        label.set_textcolor(lb, lCol)
        label.set_size(lb, lSz)
    if not na(fs.diagLn)
        line.set_color(fs.diagLn, col)
        line.set_width(fs.diagLn, 1)
        line.set_style(fs.diagLn, line.style_dotted)
    if not na(fs.bannerLb)
        txt = label.get_text(fs.bannerLb)
        if str.startswith(txt, "⏳ ")
            label.set_text(fs.bannerLb, str.replace(txt, "⏳ ", "", 0))
        label.set_color(fs.bannerLb, color.new(col, 70))
        label.set_textcolor(fs.bannerLb, col)
        label.set_size(fs.bannerLb, size.normal)

createSupportFiboSet(float lo, float hi, int startX, int endX, int dir, string tfTag, color baseCol, string xlMode) =>
    fs = FiboSet.new()
    fs.ovs_low  := lo
    fs.ovb_high := hi
    fs.status   := ST_VALID
    fs.fiboType := FT_HAK_KHO
    fs.fDir     := dir
    fs.ln := array.new<line>()
    fs.lb := array.new<label>()

    rng = hi - lo
    x1  = startX
    x2  = endX

    dirTag  = dir == 1 ? "▲" : "▼"
    nameTag = "รับ" + dirTag + " " + tfTag

    for i = 0 to array.size(SUP_FIBO_LEVELS) - 1
        lvl   = array.get(SUP_FIBO_LEVELS, i)
        price = dir == 1 ? hi - lvl * rng : lo + lvl * rng
        lbl   = array.get(SUP_FIBO_LABELS, i)
        pTxt  = str.tostring(price, format.mintick)

        is50 = i == 1
        w   = 2
        sty = is50 ? line.style_solid : line.style_dashed
        lSz = size.small

        txt = lbl + " (" + pTxt + ")"
        newLine  = line.new(x1, price, x2, price, color = baseCol, width = w, style = sty, xloc = xlMode)
        newLabel = label.new(x2, price, txt,
             style = label.style_label_left, color = color.new(color.black, 100),
             textcolor = baseCol, size = lSz, xloc = xlMode)

        array.push(fs.ln, newLine)
        array.push(fs.lb, newLabel)

    if dir == -1
        fs.diagLn := line.new(x1, hi, x2, lo, color = baseCol, width = 1, style = line.style_dashed, xloc = xlMode)
    else
        fs.diagLn := line.new(x1, lo, x2, hi, color = baseCol, width = 1, style = line.style_dashed, xloc = xlMode)

    fs.bannerLb := label.new(x2, hi, nameTag,
         style = label.style_label_lower_left, color = color.new(baseCol, 70),
         textcolor = baseCol, size = size.normal, xloc = xlMode)

    fs

// ─────────────────────────────────────────────────────────────────────────────
// TFEngine Chart-Visual Methods (marker + trend label)
// ─────────────────────────────────────────────────────────────────────────────

method updateOvsPending(TFEngine this, int _t, float _l) =>
    if i_showMarkers
        if na(this.curOvsLbl)
            this.curOvsLbl := label.new(_t, _l, "⏳ S",
                 style = label.style_label_up, color = color.new(color.aqua, 30),
                 textcolor = color.white, size = size.small, xloc = xloc.bar_time)
        label.set_x(this.curOvsLbl, _t)
        label.set_y(this.curOvsLbl, _l)

method updateOvbPending(TFEngine this, int _t, float _h) =>
    if i_showMarkers
        if na(this.curOvbLbl)
            this.curOvbLbl := label.new(_t, _h, "⏳ B",
                 style = label.style_label_down, color = color.new(color.orange, 30),
                 textcolor = color.white, size = size.small, xloc = xloc.bar_time)
        label.set_x(this.curOvbLbl, _t)
        label.set_y(this.curOvbLbl, _h)

method finalizeOvs(TFEngine this, float _kTrig, int _trigT) =>
    if not na(this.curOvsLbl)
        // Confirm OVS ตัวก่อนหน้า (ถ้ามี) → เปลี่ยนเป็นสี solid
        if not na(this.unconfOvsLbl)
            label.set_color(this.unconfOvsLbl, i_debugStoch ? color.new(color.aqua, 0) : color.aqua)
            label.set_textcolor(this.unconfOvsLbl, i_debugStoch ? color.black : color.aqua)
        // OVS ตัวปัจจุบัน → unconfirmed (semi-transparent, รอ OVS ถัดไป confirm)
        _txt = i_debugStoch ? "S\nk=" + str.tostring(_kTrig, "#.0") : "S"
        label.set_text(this.curOvsLbl, _txt)
        label.set_style(this.curOvsLbl, i_debugStoch ? label.style_label_up : label.style_diamond)
        label.set_color(this.curOvsLbl, i_debugStoch ? color.new(color.aqua, 50) : color.new(color.aqua, 60))
        label.set_textcolor(this.curOvsLbl, i_debugStoch ? color.new(color.black, 50) : color.new(color.aqua, 60))
        label.set_size(this.curOvsLbl, i_debugStoch ? size.normal : size.tiny)
        array.push(this.markers, this.curOvsLbl)
        this.lockedOvsLbl := this.curOvsLbl
        this.unconfOvsLbl := this.curOvsLbl
        this.curOvsLbl := na
        if i_debugStoch and not na(_trigT)
            _dbg = label.new(_trigT, 0, "▲TRIG\nk=" + str.tostring(_kTrig, "#.0"),
                 yloc = yloc.belowbar, style = label.style_label_up,
                 color = color.new(color.blue, 0), textcolor = color.white,
                 size = size.normal, xloc = xloc.bar_time)
            array.push(this.markers, _dbg)

method finalizeOvb(TFEngine this, float _kTrig, int _trigT) =>
    if not na(this.curOvbLbl)
        // Confirm OVB ตัวก่อนหน้า (ถ้ามี) → เปลี่ยนเป็นสี solid
        if not na(this.unconfOvbLbl)
            label.set_color(this.unconfOvbLbl, i_debugStoch ? color.new(color.orange, 0) : color.orange)
            label.set_textcolor(this.unconfOvbLbl, i_debugStoch ? color.black : color.orange)
        // OVB ตัวปัจจุบัน → unconfirmed (semi-transparent, รอ OVB ถัดไป confirm)
        _txt = i_debugStoch ? "B\nk=" + str.tostring(_kTrig, "#.0") : "B"
        label.set_text(this.curOvbLbl, _txt)
        label.set_style(this.curOvbLbl, i_debugStoch ? label.style_label_down : label.style_diamond)
        label.set_color(this.curOvbLbl, i_debugStoch ? color.new(color.orange, 50) : color.new(color.orange, 60))
        label.set_textcolor(this.curOvbLbl, i_debugStoch ? color.new(color.black, 50) : color.new(color.orange, 60))
        label.set_size(this.curOvbLbl, i_debugStoch ? size.normal : size.tiny)
        array.push(this.markers, this.curOvbLbl)
        this.lockedOvbLbl := this.curOvbLbl
        this.unconfOvbLbl := this.curOvbLbl
        this.curOvbLbl := na
        if i_debugStoch and not na(_trigT)
            _dbg = label.new(_trigT, 0, "▼TRIG\nk=" + str.tostring(_kTrig, "#.0"),
                 yloc = yloc.abovebar, style = label.style_label_down,
                 color = color.new(color.red, 0), textcolor = color.white,
                 size = size.normal, xloc = xloc.bar_time)
            array.push(this.markers, _dbg)

method pushTrendLabel(TFEngine this, int _t, float _y, int newTrend, bool ovsSide) =>
    if i_showTrend and newTrend != 0
        isWarn = newTrend == 2 or newTrend == -2
        txt = newTrend == 2  ? (ovsSide ? "⚠HL" : "⚠HH") :
               newTrend == -2 ? (ovsSide ? "⚠LL" : "⚠LH") :
               newTrend == 1  ? "UP" : "DN"
        bg = isWarn           ? color.new(color.yellow, 10) :
              newTrend == 1   ? color.new(color.green, 10)  :
              color.new(color.red, 10)
        fg = isWarn ? color.black : color.white
        sty = ovsSide ? label.style_label_up : label.style_label_down
        lbl = label.new(_t, _y, txt,
             style = sty, color = bg, textcolor = fg,
             size = isWarn ? size.small : size.normal,
             xloc = xloc.bar_time)
        array.push(this.trendLabels, lbl)

method cleanupVisuals(TFEngine this) =>
    while array.size(this.markers) > i_maxMarkers * 2
        label.delete(array.get(this.markers, 0))
        array.remove(this.markers, 0)
    while array.size(this.trendLabels) > 20
        label.delete(array.get(this.trendLabels, 0))
        array.remove(this.trendLabels, 0)

// ─────────────────────────────────────────────────────────────────────────────
// TFEngine Core Methods
// ─────────────────────────────────────────────────────────────────────────────

method tick(TFEngine this, float _h, float _l, float _c, float _k, int _t, bool isChartTF) =>
    _isOvs = _k < i_ovsLevel
    _isOvb = _k > i_ovbLevel
    _xl    = xloc.bar_time

    // ─── Phase 1: SM_WAIT_OVS — track lowest low (pending OVS), lock ที่ K>80 ───
    // + Bounded OVB movement: ขยับ OVB ขึ้นได้เฉพาะ wick ที่อยู่ระหว่าง 2 valleys
    if this.sm == SM_WAIT_OVS
        if na(this.ovsLo) or _l < this.ovsLo
            // valley ใหม่ → commit highSinceValley (ขยับ OVB ถ้าสูงกว่า)
            if not na(this.lockedOvbHi) and not na(this.highSinceValley) and this.highSinceValley > this.lockedOvbHi
                this.lockedOvbHi  := this.highSinceValley
                this.lockedOvbHiT := this.highSinceValleyT
                this.prevOvbHi    := this.highSinceValley
                this.prevOvbHiT   := this.highSinceValleyT
                this.confOvbHi    := this.highSinceValley
                this.confOvbHiT   := this.highSinceValleyT
                if isChartTF and not na(this.lockedOvbLbl)
                    label.set_x(this.lockedOvbLbl, this.highSinceValleyT)
                    label.set_y(this.lockedOvbLbl, this.highSinceValley)
            this.highSinceValley  := na
            this.highSinceValleyT := na
            this.ovsLo  := _l
            this.ovsLoT := _t
            if isChartTF
                this.updateOvsPending(_t, _l)
        else
            // ไม่ใช่ valley ใหม่ → ติดตาม highest high ระหว่าง valley เก่า → valley ปัจจุบัน
            if na(this.highSinceValley) or _h > this.highSinceValley
                this.highSinceValley  := _h
                this.highSinceValleyT := _t

        // K>80 → confirm OVS, transition; ovbHi reset → track ใหม่ที่ trigger bar
        if _isOvb and not na(this.ovsLo)
            _sLo  = this.ovsLo
            _sLoT = this.ovsLoT

            // เก็บ position ของ OVS ที่เพิ่ง finalize → ขยับต่อได้ใน SM_WAIT_OVB
            this.lockedOvsLo  := _sLo
            this.lockedOvsLoT := _sLoT
            if isChartTF
                this.finalizeOvs(_k, _t)

            _isHL = not na(this.prevOvsLo) and _sLo > this.prevOvsLo
            _isLL = not na(this.prevOvsLo) and _sLo < this.prevOvsLo
            _fT   = _isHL ? FT_SOMBOON : FT_HAK_KHO
            _fNm  = _fT == FT_SOMBOON ? "SB" : "HK"

            if not na(this.prevOvsLo)
                _newTrend = trendAfterOvs(this.trend, _isHL, _isLL)
                if _newTrend != this.trend
                    this.trend := _newTrend
                    if isChartTF
                        this.pushTrendLabel(_sLoT, _sLo, _newTrend, true)

            this.prevOvsLo  := _sLo
            this.prevOvsLoT := _sLoT

            if expirePendingFibos(this.targetSets, -1) > 0
                this.canDrawDn := true

            // UP Fibo (จาก OVB เก่า ↘ OVS ใหม่)
            if this.showTarget and this.canDrawUp and not na(this.confOvbHi) and this.confOvbHi > _sLo
                _show = _fT == FT_HAK_KHO ? i_showHK : i_showSB
                if _show
                    _nf = createFiboSet(_sLo, this.confOvbHi, this.confOvbHiT, _sLoT, _fT, _fNm, 1, this.tfTag, _xl, this.showPending)
                    array.push(this.targetSets, _nf)
                    this.canDrawUp := false
                    trimFiboSets(this.targetSets, 1, i_maxSets)

            if this.showEntry and not na(this.confOvbHi) and this.confOvbHi > _sLo
                _ns = createSupportFiboSet(_sLo, this.confOvbHi, this.confOvbHiT, _sLoT, -1, this.tfTag, this.col, _xl)
                array.push(this.entrySets, _ns)
                trimFiboSets(this.entrySets, -1, i_maxSupSets)

            this.sm     := SM_WAIT_OVB
            this.ovsLo  := na
            this.ovsLoT := na
            // Reset ovbHi เริ่ม track ใหม่ที่ K>80 trigger bar เพื่อไม่ให้ peak ก่อน trigger ทับ OVS marker
            this.ovbHi  := _h
            this.ovbHiT := _t
            // Reset lowSincePeak (เริ่ม track ใหม่ใน SM_WAIT_OVB)
            this.lowSincePeak  := na
            this.lowSincePeakT := na
            // Lock OVB marker (ขยับไม่ได้แล้ว เพราะ OVS confirm แล้ว)
            this.lockedOvbLbl := na
            this.lockedOvbHi  := na
            this.lockedOvbHiT := na
            this.highSinceValley  := na
            this.highSinceValleyT := na

            if isChartTF
                this.updateOvbPending(_t, _h)

    // ─── Phase 2: SM_WAIT_OVB — track highest high (pending OVB), lock ที่ K<20 ───
    // Option C (จำกัด): ขยับ OVS ได้เฉพาะ wick ที่อยู่ "ระหว่าง peak เก่า → peak ใหม่"
    //   - lowSincePeak track lowest low หลัง peak ล่าสุด
    //   - เจอ peak ใหม่ → commit lowSincePeak (ถ้าต่ำกว่า lockedOvsLo → ขยับ marker)
    //   - ถ้าไม่มี peak ใหม่จนถึง K<20 → wick นั้นกลายเป็น pending OVS รอบถัดไป (รักษา alternation)
    else if this.sm == SM_WAIT_OVB
        if na(this.ovbHi) or _h > this.ovbHi
            // เจอ peak ใหม่ → commit wick ระหว่าง peak เก่า/ใหม่ ไปเป็น OVS ของรอบนี้
            if not na(this.lockedOvsLo) and not na(this.lowSincePeak) and this.lowSincePeak < this.lockedOvsLo
                this.lockedOvsLo  := this.lowSincePeak
                this.lockedOvsLoT := this.lowSincePeakT
                this.prevOvsLo    := this.lowSincePeak
                this.prevOvsLoT   := this.lowSincePeakT
                if isChartTF and not na(this.lockedOvsLbl)
                    label.set_x(this.lockedOvsLbl, this.lowSincePeakT)
                    label.set_y(this.lockedOvsLbl, this.lowSincePeak)
            this.ovbHi  := _h
            this.ovbHiT := _t
            this.lowSincePeak  := na
            this.lowSincePeakT := na
            if isChartTF
                this.updateOvbPending(_t, _h)
        else
            // ไม่ใช่ peak ใหม่ → ติดตาม lowest low ระหว่าง peak เก่า → peak ปัจจุบัน
            if na(this.lowSincePeak) or _l < this.lowSincePeak
                this.lowSincePeak  := _l
                this.lowSincePeakT := _t

        // K<20 → confirm OVB, lock OVS (no more moves), transition
        if _isOvs
            _fHi  = this.ovbHi
            _fHiT = this.ovbHiT

            if isChartTF
                this.finalizeOvb(_k, _t)

            _isHH = not na(this.prevOvbHi) and _fHi > this.prevOvbHi
            _isLH = not na(this.prevOvbHi) and _fHi < this.prevOvbHi

            if not na(this.prevOvbHi)
                _newTrend = trendAfterOvb(this.trend, _isHH, _isLH)
                if _newTrend != this.trend
                    this.trend := _newTrend
                    if isChartTF
                        this.pushTrendLabel(_fHiT, _fHi, _newTrend, false)

            if expirePendingFibos(this.targetSets, 1) > 0
                this.canDrawUp := true

            _dnFT  = _isLH ? FT_SOMBOON : FT_HAK_KHO
            _dnFNm = _dnFT == FT_SOMBOON ? "SB" : "HK"

            this.prevOvbHi   := _fHi
            this.prevOvbHiT  := _fHiT
            this.confOvbHi   := _fHi
            this.confOvbHiT  := _fHiT

            // DN Fibo (จาก OVS เก่า ↗ OVB ใหม่)
            if this.showTarget and this.canDrawDn and not na(this.prevOvsLo) and _fHi > this.prevOvsLo
                _show = _dnFT == FT_HAK_KHO ? i_showHK : i_showSB
                if _show
                    _nf = createFiboSet(this.prevOvsLo, _fHi, this.prevOvsLoT, _fHiT, _dnFT, _dnFNm, -1, this.tfTag, _xl, this.showPending)
                    array.push(this.targetSets, _nf)
                    this.canDrawDn := false
                    trimFiboSets(this.targetSets, -1, i_maxSets)

            if this.showEntry and not na(this.prevOvsLo) and _fHi > this.prevOvsLo
                _ns = createSupportFiboSet(this.prevOvsLo, _fHi, this.prevOvsLoT, _fHiT, 1, this.tfTag, this.col, _xl)
                array.push(this.entrySets, _ns)
                trimFiboSets(this.entrySets, 1, i_maxSupSets)

            this.sm     := SM_WAIT_OVS
            this.ovbHi  := na
            this.ovbHiT := na
            // Lock OVS marker (no more moves สำหรับ cycle ที่เพิ่งจบ)
            this.lockedOvsLbl := na
            this.lockedOvsLo  := na
            this.lockedOvsLoT := na
            // Setup locked OVB → ขยับขึ้นได้ใน SM_WAIT_OVS ถ้าเจอ high สูงกว่า
            this.lockedOvbHi  := _fHi
            this.lockedOvbHiT := _fHiT
            this.highSinceValley  := na
            this.highSinceValleyT := na
            // wick หลัง peak สุดท้าย (lowSincePeak) → กลายเป็น pending OVS รอบถัดไป
            // เทียบกับ trigger bar ใช้อันที่ต่ำกว่า
            if not na(this.lowSincePeak) and this.lowSincePeak < _l
                this.ovsLo  := this.lowSincePeak
                this.ovsLoT := this.lowSincePeakT
            else
                this.ovsLo  := _l
                this.ovsLoT := _t
            this.lowSincePeak  := na
            this.lowSincePeakT := na

            if isChartTF
                this.updateOvsPending(this.ovsLoT, this.ovsLo)

method destroyFibos(TFEngine this, float barH, float barL, float barC) =>
    if array.size(this.targetSets) > 0
        _toD = array.new<int>()
        for i = 0 to array.size(this.targetSets) - 1
            fs = array.get(this.targetSets, i)
            rng = fs.ovb_high - fs.ovs_low
            if fs.fDir == 1
                if barH > fs.ovs_low + 4.236 * rng or barL < fs.ovs_low
                    array.push(_toD, i)
            else
                if barL < fs.ovb_high - 4.236 * rng or barH > fs.ovb_high
                    array.push(_toD, i)
            if fs.status == ST_PENDING
                if fs.fDir == 1
                    if fs.fiboType == FT_SOMBOON
                        if barH > fs.ovs_low + 1.0 * rng
                            fs.status := ST_VALID
                            confirmFiboSet(fs, this.col)
                            this.canDrawUp := true
                    else
                        if barC > fs.ovs_low + 1.618 * rng
                            fs.status := ST_VALID
                            confirmFiboSet(fs, this.col)
                            this.canDrawUp := true
                else
                    if fs.fiboType == FT_SOMBOON
                        if barL < fs.ovb_high - 1.0 * rng
                            fs.status := ST_VALID
                            confirmFiboSet(fs, this.col)
                            this.canDrawDn := true
                    else
                        if barC < fs.ovb_high - 1.618 * rng
                            fs.status := ST_VALID
                            confirmFiboSet(fs, this.col)
                            this.canDrawDn := true
        if array.size(_toD) > 0
            for jj = array.size(_toD) - 1 to 0
                _idx = array.get(_toD, jj)
                _dFs = array.get(this.targetSets, _idx)
                if _dFs.status == ST_PENDING
                    if _dFs.fDir == 1
                        this.canDrawUp := true
                    else
                        this.canDrawDn := true
                deleteFiboSet(_dFs)
                array.remove(this.targetSets, _idx)
    if array.size(this.entrySets) > 0
        _toDS = array.new<int>()
        for i = 0 to array.size(this.entrySets) - 1
            fs = array.get(this.entrySets, i)
            if barL < fs.ovs_low or barH > fs.ovb_high
                array.push(_toDS, i)
        if array.size(_toDS) > 0
            for jj = array.size(_toDS) - 1 to 0
                deleteFiboSet(array.get(this.entrySets, array.get(_toDS, jj)))
                array.remove(this.entrySets, array.get(_toDS, jj))

method feedLowerTF(TFEngine this, float[] _aH, float[] _aL, float[] _aC, float[] _aK, int[] _aT) =>
    for j = 0 to array.size(_aH) - 1
        this.tick(array.get(_aH, j), array.get(_aL, j), array.get(_aC, j), array.get(_aK, j), array.get(_aT, j), false)
        this.destroyFibos(array.get(_aH, j), array.get(_aL, j), array.get(_aC, j))

method feedHigherTF(TFEngine this, float _k, float _h, float _l, float _c, int _t, bool isLast) =>
    if not na(_t)
        if na(this.prevBarT)
            this.prevBarT := _t
        else if _t != this.prevBarT
            this.tick(this.cacheH, this.cacheL, this.cacheC, this.cacheK, this.prevBarT, false)
            this.destroyFibos(this.cacheH, this.cacheL, this.cacheC)
            this.prevBarT := _t
        this.cacheK := _k
        this.cacheH := _h
        this.cacheL := _l
        this.cacheC := _c
        if isLast and not na(this.cacheK)
            this.tick(this.cacheH, this.cacheL, this.cacheC, this.cacheK, this.prevBarT, false)
            this.destroyFibos(this.cacheH, this.cacheL, this.cacheC)

method process(TFEngine this, bool isChartTF, int ltSz, float[] ltH, float[] ltL, float[] ltC, float[] ltK, int[] ltT, float rsK, float rsH, float rsL, float rsC, int rsT) =>
    if isChartTF
        // visuals ถูกจัดการโดย engChart แยก → MTF engine ตัวนี้ไม่ต้องวาด marker/trend
        this.tick(high, low, close, kVal, time, false)
        this.destroyFibos(high, low, close)
    else if ltSz > 0
        this.feedLowerTF(ltH, ltL, ltC, ltK, ltT)
    else
        this.feedHigherTF(rsK, rsH, rsL, rsC, rsT, barstate.islast)

// ─────────────────────────────────────────────────────────────────────────────
// TFEngine Instances
// ─────────────────────────────────────────────────────────────────────────────

var TFEngine engDay = TFEngine.new(tfTag = "Day", col = i_dayCol, showTarget = i_dayTarget, showEntry = i_dayEntry, showPending = i_dayPending,
     targetSets = array.new<FiboSet>(), entrySets = array.new<FiboSet>(),
     markers = array.new<label>(), trendLabels = array.new<label>())
var TFEngine engH4  = TFEngine.new(tfTag = "H4",  col = i_h4Col,  showTarget = i_h4Target,  showEntry = i_h4Entry,  showPending = i_h4Pending,
     targetSets = array.new<FiboSet>(), entrySets = array.new<FiboSet>(),
     markers = array.new<label>(), trendLabels = array.new<label>())
var TFEngine engH1  = TFEngine.new(tfTag = "H1",  col = i_h1Col,  showTarget = i_h1Target,  showEntry = i_h1Entry,  showPending = i_h1Pending,
     targetSets = array.new<FiboSet>(), entrySets = array.new<FiboSet>(),
     markers = array.new<label>(), trendLabels = array.new<label>())
var TFEngine engM15 = TFEngine.new(tfTag = "M15", col = i_m15Col, showTarget = i_m15Target, showEntry = i_m15Entry, showPending = i_m15Pending,
     targetSets = array.new<FiboSet>(), entrySets = array.new<FiboSet>(),
     markers = array.new<label>(), trendLabels = array.new<label>())
var TFEngine engM5  = TFEngine.new(tfTag = "M5",  col = i_m5Col,  showTarget = i_m5Target,  showEntry = i_m5Entry,  showPending = i_m5Pending,
     targetSets = array.new<FiboSet>(), entrySets = array.new<FiboSet>(),
     markers = array.new<label>(), trendLabels = array.new<label>())
var TFEngine engM1  = TFEngine.new(tfTag = "M1",  col = i_m1Col,  showTarget = i_m1Target,  showEntry = i_m1Entry,  showPending = i_m1Pending,
     targetSets = array.new<FiboSet>(), entrySets = array.new<FiboSet>(),
     markers = array.new<label>(), trendLabels = array.new<label>())

// Dedicated engine สำหรับ chart-TF visuals (marker + trend) — ไม่สร้าง Fibo
// ทำงานทุก TF โดยไม่ขึ้นกับการเปิด/ปิด target/entry ของ TF ใด
var TFEngine engChart = TFEngine.new(tfTag = "", col = color.gray,
     showTarget = false, showEntry = false, showPending = false,
     targetSets = array.new<FiboSet>(), entrySets = array.new<FiboSet>(),
     markers = array.new<label>(), trendLabels = array.new<label>())

// ─────────────────────────────────────────────────────────────────────────────
// RSI Mountain Cut State Machine (คงเดิม, แยกจาก Stoch SM)
// ─────────────────────────────────────────────────────────────────────────────

var int  RSI_WAIT_FIRST_OVS  = 0
var int  RSI_WAIT_OVB        = 1
var int  RSI_WAIT_SECOND_OVS = 2

var int   rsiCutState = RSI_WAIT_FIRST_OVS
var bool  rsiCutBar   = false

if i_rsiCutEnabled
    rsiCutBar := false
    if rsiCutState == RSI_WAIT_FIRST_OVS and rsiInOvs
        rsiCutState := RSI_WAIT_OVB
    else if rsiCutState == RSI_WAIT_OVB and rsiInOvb
        rsiCutState := RSI_WAIT_SECOND_OVS
    else if rsiCutState == RSI_WAIT_SECOND_OVS and rsiInOvs
        rsiCutBar  := true
        rsiCutState := RSI_WAIT_FIRST_OVS

bgcolor(i_rsiCutEnabled and rsiCutBar ? color.new(color.purple, 70) : na, title = "RSI CUT")

// ─────────────────────────────────────────────────────────────────────────────
// Multi-TF Engine Processing
// ─────────────────────────────────────────────────────────────────────────────

chartSec   = timeframe.in_seconds()
isChartDay = chartSec == timeframe.in_seconds("D")
isChartH4  = chartSec == timeframe.in_seconds("240")
isChartH1  = chartSec == timeframe.in_seconds("60")
isChartM15 = chartSec == timeframe.in_seconds("15")
isChartM5  = chartSec == timeframe.in_seconds("5")
isChartM1  = chartSec == timeframe.in_seconds("1")

ltSz_d  = not na(ltH_d)  ? array.size(ltH_d)  : 0
ltSz_4h = not na(ltH_4h) ? array.size(ltH_4h) : 0
ltSz_1h = not na(ltH_1h) ? array.size(ltH_1h) : 0
ltSz_15 = not na(ltH_15) ? array.size(ltH_15) : 0
ltSz_5  = not na(ltH_5)  ? array.size(ltH_5)  : 0
ltSz_1m = not na(ltH_1m) ? array.size(ltH_1m) : 0

// engChart รันทุกบาร์บน chart TF → รับผิดชอบ marker + trend label อย่างเดียว
engChart.tick(high, low, close, kVal, time, true)
engChart.destroyFibos(high, low, close)

// MTF engines รับผิดชอบเฉพาะ Fibo ของ TF นั้นๆ
if i_dayTarget or i_dayEntry
    engDay.process(isChartDay, ltSz_d, ltH_d, ltL_d, ltC_d, ltK_d, ltT_d, rsK_d, rsH_d, rsL_d, rsC_d, rsT_d)
if i_h4Target or i_h4Entry
    engH4.process(isChartH4, ltSz_4h, ltH_4h, ltL_4h, ltC_4h, ltK_4h, ltT_4h, rsK_4h, rsH_4h, rsL_4h, rsC_4h, rsT_4h)
if i_h1Target or i_h1Entry
    engH1.process(isChartH1, ltSz_1h, ltH_1h, ltL_1h, ltC_1h, ltK_1h, ltT_1h, rsK_1h, rsH_1h, rsL_1h, rsC_1h, rsT_1h)
if i_m15Target or i_m15Entry
    engM15.process(isChartM15, ltSz_15, ltH_15, ltL_15, ltC_15, ltK_15, ltT_15, rsK_15, rsH_15, rsL_15, rsC_15, rsT_15)
if i_m5Target or i_m5Entry
    engM5.process(isChartM5, ltSz_5, ltH_5, ltL_5, ltC_5, ltK_5, ltT_5, rsK_5, rsH_5, rsL_5, rsC_5, rsT_5)
if i_m1Target or i_m1Entry
    engM1.process(isChartM1, ltSz_1m, ltH_1m, ltL_1m, ltC_1m, ltK_1m, ltT_1m, rsK_1m, rsH_1m, rsL_1m, rsC_1m, rsT_1m)

// ─────────────────────────────────────────────────────────────────────────────
// Cleanup visuals (หลักๆ คือ engChart — ตัวอื่นไม่สร้าง marker จึงเงียบ)
// ─────────────────────────────────────────────────────────────────────────────

engChart.cleanupVisuals()

// ─────────────────────────────────────────────────────────────────────────────
// Zone Visualization
// ─────────────────────────────────────────────────────────────────────────────

bgcolor(i_showZones and inOvs ? color.new(color.blue, 88) : na, title = "OVS Zone")
bgcolor(i_showZones and inOvb ? color.new(color.red, 88) : na,  title = "OVB Zone")

// ─────────────────────────────────────────────────────────────────────────────
// EMA 14 / 60 + Cross Background
// ─────────────────────────────────────────────────────────────────────────────

emaFast = ta.ema(close, i_emaFast)
emaSlow = ta.ema(close, i_emaSlow)

pFast = plot(i_showEMA ? emaFast : na, "EMA Fast", color.new(color.yellow, 0), 2)
pSlow = plot(i_showEMA ? emaSlow : na, "EMA Slow", color.new(#FF9800, 0), 2)

cloudCol = emaFast > emaSlow ? color.new(color.green, 85) : color.new(color.red, 85)
fill(pFast, pSlow, i_showEMAbg ? cloudCol : na, title = "EMA Cloud")

// ─────────────────────────────────────────────────────────────────────────────
// H4 EMA (H1 only)
// ─────────────────────────────────────────────────────────────────────────────

htfEmaRaw  = ta.ema(close, i_htfEMA_Len)
htfEmaVal  = request.security(syminfo.tickerid, "240", htfEmaRaw)
htfAbove   = close > htfEmaVal
showHTF    = i_showHTF_EMA and isChartH1
htfCol     = showHTF ? color.new(i_htfEMA_Col, htfAbove ? 0 : 50) : na

plot(showHTF ? htfEmaVal : na, "H4 EMA", htfCol, 3, plot.style_line)

// ─────────────────────────────────────────────────────────────────────────────
// Status Panel
// ─────────────────────────────────────────────────────────────────────────────

engCount(TFEngine eng) =>
    _tp = 0
    _tv = 0
    if array.size(eng.targetSets) > 0
        for i = 0 to array.size(eng.targetSets) - 1
            if array.get(eng.targetSets, i).status == ST_PENDING
                _tp += 1
            else
                _tv += 1
    _ec = array.size(eng.entrySets)
    [_tv, _tp, _ec, eng.trend]

momCol(int st) =>
    st == 2 ? color.rgb(0, 230, 64) : st == -2 ? color.rgb(255, 23, 23) : st == 1 ? color.rgb(0, 230, 64, 50) : st == -1 ? color.rgb(255, 23, 23, 50) : color.gray

momTxt(int st) =>
    st == 2 ? "⬆⬆" : st == -2 ? "⬇⬇" : st == 1 ? "⬆" : st == -1 ? "⬇" : "–"

trendArrow(int tr) =>
    tr == 1 ? "▲" : tr == -1 ? "▼" : tr == 2 ? "⚠▲" : tr == -2 ? "⚠▼" : "─"

trendColor(int tr) =>
    tr == 1 ? color.green : tr == -1 ? color.red : tr == 2 or tr == -2 ? color.yellow : color.gray

momRow(table tbl, int row, string name, int st, string hSz, string vSz) =>
    table.cell(tbl, 0, row, name, text_color = color.gray, text_size = hSz, text_halign = text.align_right)
    table.cell(tbl, 1, row, momTxt(st), text_color = momCol(st), text_size = vSz, text_halign = text.align_center)
    table.cell(tbl, 2, row, "", text_size = size.tiny)
    row + 1

fiboRow(table tbl, int row, TFEngine eng, string name, color tfCol, string hSz) =>
    [_tv, _tp, _ec, _tr] = engCount(eng)
    _tot = _tv + _tp
    _txt = (_tot > 0 ? str.tostring(_tot) + "เป้า" : "") + (_tp > 0 ? "(" + str.tostring(_tp) + "⏳)" : "") + (_ec > 0 ? " " + str.tostring(_ec) + "รับ" : "")
    table.cell(tbl, 0, row, name, text_color = tfCol, text_size = hSz, text_halign = text.align_right)
    table.cell(tbl, 1, row, trendArrow(_tr), text_color = trendColor(_tr), text_size = hSz, text_halign = text.align_center)
    table.cell(tbl, 2, row, _txt, text_color = tfCol, text_size = size.tiny, text_halign = text.align_left)
    row + 1

// อ่าน trend / sm จาก engChart (ซึ่งรันบน chart TF โดยตรง)
chartTrend = engChart.trend
chartSm    = engChart.sm

if barstate.islast
    var table statusTbl = table.new(position.bottom_right, 3, 20,
         bgcolor = color.new(#1E1E1E, 0), border_color = color.new(#333333, 0), border_width = 1,
         frame_color = color.new(#555555, 0), frame_width = 2)

    hSz = size.small
    vSz = size.small
    sepBg = color.new(#2A2A2A, 0)

    trendTxt = chartTrend == 1 ? "▲ UP" : chartTrend == -1 ? "▼ DN" : chartTrend == 2 ? "⚠ HL" : chartTrend == -2 ? "⚠ LH" : "─"
    trendCol = chartTrend == 1 ? color.green : chartTrend == -1 ? color.red : chartTrend == 2 or chartTrend == -2 ? color.yellow : color.gray
    trendBg  = color.new(trendCol, 85)
    emaTxt   = emaFast > emaSlow ? "EMA+" : "EMA−"
    emaCol   = emaFast > emaSlow ? color.green : color.red
    kTxt     = str.tostring(kVal, "#")
    smCol    = chartSm == SM_WAIT_OVS ? color.aqua : color.orange
    smTxt    = chartSm == SM_WAIT_OVS ? "OVS" : "OVB"

    htfTxt   = htfAbove ? "H4▲" : "H4▼"
    htfTCol  = htfAbove ? color.new(i_htfEMA_Col, 0) : color.new(i_htfEMA_Col, 50)

    table.cell(statusTbl, 0, 0, trendTxt, text_color = trendCol, text_size = size.normal, text_halign = text.align_center, bgcolor = trendBg)
    table.cell(statusTbl, 1, 0, emaTxt, text_color = emaCol, text_size = vSz, text_halign = text.align_center, bgcolor = trendBg)
    table.cell(statusTbl, 2, 0, smTxt + " " + kTxt, text_color = smCol, text_size = vSz, text_halign = text.align_center, bgcolor = trendBg)

    rowIdx = 1

    if i_showHTF_EMA and isChartH1
        table.cell(statusTbl, 0, rowIdx, "H4 EMA", text_color = color.gray, text_size = hSz, text_halign = text.align_right)
        table.cell(statusTbl, 1, rowIdx, htfTxt, text_color = htfTCol, text_size = vSz, text_halign = text.align_center)
        table.cell(statusTbl, 2, rowIdx, str.tostring(htfEmaVal, format.mintick), text_color = htfTCol, text_size = size.tiny, text_halign = text.align_left)
        rowIdx += 1

    if i_showMom
        table.cell(statusTbl, 0, rowIdx, "", bgcolor = sepBg)
        table.cell(statusTbl, 1, rowIdx, "🕯", text_color = color.new(color.white, 40), text_size = size.tiny, text_halign = text.align_center, bgcolor = sepBg)
        table.cell(statusTbl, 2, rowIdx, "", bgcolor = sepBg)
        rowIdx += 1
        if i_momDay
            rowIdx := momRow(statusTbl, rowIdx, "D",   momState_day, hSz, vSz)
        if i_momH4
            rowIdx := momRow(statusTbl, rowIdx, "H4",  momState_h4,  hSz, vSz)
        if i_momH1
            rowIdx := momRow(statusTbl, rowIdx, "H1",  momState_h1,  hSz, vSz)
        if i_momM15
            rowIdx := momRow(statusTbl, rowIdx, "M15", momState_m15, hSz, vSz)
        if i_momM5
            rowIdx := momRow(statusTbl, rowIdx, "M5",  momState_m5,  hSz, vSz)
        if i_momM3
            rowIdx := momRow(statusTbl, rowIdx, "M3",  momState_m3,  hSz, vSz)
        if i_momM1
            rowIdx := momRow(statusTbl, rowIdx, "M1",  momState_m1,  hSz, vSz)

    if i_dayTarget or i_dayEntry or i_h4Target or i_h4Entry or i_h1Target or i_h1Entry or i_m15Target or i_m15Entry or i_m5Target or i_m5Entry or i_m1Target or i_m1Entry
        table.cell(statusTbl, 0, rowIdx, "", bgcolor = sepBg)
        table.cell(statusTbl, 1, rowIdx, "📊", text_color = color.new(color.white, 40), text_size = size.tiny, text_halign = text.align_center, bgcolor = sepBg)
        table.cell(statusTbl, 2, rowIdx, "", bgcolor = sepBg)
        rowIdx += 1

    if i_dayTarget or i_dayEntry
        rowIdx := fiboRow(statusTbl, rowIdx, engDay,  "Day", i_dayCol, hSz)
    if i_h4Target or i_h4Entry
        rowIdx := fiboRow(statusTbl, rowIdx, engH4,   "H4",  i_h4Col,  hSz)
    if i_h1Target or i_h1Entry
        rowIdx := fiboRow(statusTbl, rowIdx, engH1,   "H1",  i_h1Col,  hSz)
    if i_m15Target or i_m15Entry
        rowIdx := fiboRow(statusTbl, rowIdx, engM15,  "M15", i_m15Col, hSz)
    if i_m5Target or i_m5Entry
        rowIdx := fiboRow(statusTbl, rowIdx, engM5,   "M5",  i_m5Col,  hSz)
    if i_m1Target or i_m1Entry
        rowIdx := fiboRow(statusTbl, rowIdx, engM1,   "M1",  i_m1Col,  hSz)
