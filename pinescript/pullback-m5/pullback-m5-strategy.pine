// LOSTXKER — Pullback EMA H1 + M15 + M5 Strategy
// ================================================
// Signal logic synced from pullback-m5.pine (indicator)
// + SL at Swing Low/High M5 + TP RR + Risk % sizing
//
// States (TDI level, EMA dist) = realtime / Events (touch, cross) = confirmed
//@version=6
strategy("LX PB M5 Strategy", shorttitle="LX PB M5 STR", overlay=true, max_bars_back=500,
     initial_capital=10000, default_qty_type=strategy.fixed, default_qty_value=1,
     commission_type=strategy.commission.percent, commission_value=0,
     slippage=1, pyramiding=0, margin_long=1, margin_short=1)

// ============================================================================
// INPUTS — SIGNAL
// ============================================================================
string GRP_BIAS = "H4 BIAS"
int    h4EmaLen = input.int(60, "EMA Length (H4 bias)", minval=1, group=GRP_BIAS)

string GRP_EMA = "H1 EMA TOUCH"
int    emaFastLen = input.int(14, "EMA Fast (H1)", minval=1, group=GRP_EMA)
int    emaSlowLen = input.int(60, "EMA Slow (H1)", minval=1, group=GRP_EMA)
bool   touch14    = input.bool(true, "Allow touch EMA14", group=GRP_EMA)
bool   touch60    = input.bool(true, "Allow touch EMA60", group=GRP_EMA)

string GRP_TDI = "TDI (shared all TF)"
int    rsiPeriod = input.int(13, "RSI Period",                     minval=1, group=GRP_TDI)
int    bandLen   = input.int(31, "Band Length (= Mid SMA period)", minval=1, group=GRP_TDI)
int    pricePer  = input.int(1,  "Price Line Period (SMA of RSI)", minval=1, group=GRP_TDI)
int    slowPer   = input.int(9,  "Sentiment Slow MA",              minval=1, group=GRP_TDI)

string GRP_FILTER = "FILTERS"
bool   enableA      = input.bool(true, "Enable ชุด A (Standard)",    group=GRP_FILTER)
bool   enableB      = input.bool(true, "Enable ชุด B (Early entry)", group=GRP_FILTER)
float  earlyMinRsi  = input.float(40, "Early entry min RSI (ชุด B)", minval=20, maxval=50, step=1, group=GRP_FILTER)
int    armedTimeout = input.int(3,    "Armed timeout (H1 bars)",     minval=1, maxval=20, group=GRP_FILTER)
float  minEmaDist   = input.float(0,  "Min EMA14-60 distance (pts)", minval=0, step=0.5, group=GRP_FILTER)
string sessionTime  = input.string("0730-0100", "Session filter (TH time)", group=GRP_FILTER)

// ============================================================================
// INPUTS — STRATEGY
// ============================================================================
string GRP_STRAT = "STRATEGY"
int    swingLen   = input.int(10,    "Swing lookback (M5 bars)",  minval=3,   maxval=50,  group=GRP_STRAT)
float  slBuffer   = input.float(0,   "SL buffer (pts)",          minval=0,   step=0.5,   group=GRP_STRAT)
float  rrRatio    = input.float(1.5,  "Risk:Reward ratio",       minval=0.5, maxval=5.0, step=0.1, group=GRP_STRAT)
float  riskPct    = input.float(1.0,  "Risk % per trade",        minval=0.1, maxval=10,  step=0.1, group=GRP_STRAT)

string GRP_DISP = "DISPLAY"
bool   showSlTp  = input.bool(true, "Show SL/TP lines", group=GRP_DISP)

// ============================================================================
// H4 BIAS (confirmed bar, no repaint)
// ============================================================================
[h4Close, h4Ema] = request.security(syminfo.tickerid, "240",
     [close[1], ta.ema(close, h4EmaLen)[1]],
     lookahead=barmerge.lookahead_on)

bool buyBias  = h4Close > h4Ema
bool sellBias = h4Close < h4Ema

// ============================================================================
// H1 DATA — states: realtime / events: confirmed
// ============================================================================
[usePrice, useMid, useSlow, useEmaDist,
 tdiBuyA, tdiSellA] = request.security(
     syminfo.tickerid, "60",
     [ta.sma(ta.rsi(close, rsiPeriod), pricePer),
      ta.sma(ta.rsi(close, rsiPeriod), bandLen),
      ta.sma(ta.rsi(close, rsiPeriod), slowPer),
      math.abs(ta.ema(close, emaFastLen) - ta.ema(close, emaSlowLen)),
      ta.sma(ta.rsi(close, rsiPeriod), pricePer) > ta.sma(ta.rsi(close, rsiPeriod), bandLen),
      ta.sma(ta.rsi(close, rsiPeriod), pricePer) < ta.sma(ta.rsi(close, rsiPeriod), bandLen)],
     lookahead=barmerge.lookahead_off)

[h1Low, h1High, h1Close, h1Open, h1EmaF, h1EmaS,
 priceCrossUpSlow, priceCrossDnSlow] = request.security(
     syminfo.tickerid, "60",
     [low[1], high[1], close[1], open[1],
      ta.ema(close, emaFastLen)[1],
      ta.ema(close, emaSlowLen)[1],
      ta.crossover(ta.sma(ta.rsi(close, rsiPeriod), pricePer),
                   ta.sma(ta.rsi(close, rsiPeriod), slowPer))[1],
      ta.crossunder(ta.sma(ta.rsi(close, rsiPeriod), pricePer),
                    ta.sma(ta.rsi(close, rsiPeriod), slowPer))[1]],
     lookahead=barmerge.lookahead_on)

bool emaTouchBuy  = (touch14 and h1Low <= h1EmaF and h1Close > h1EmaF) or (touch60 and h1Low <= h1EmaS and h1Close > h1EmaS)
bool emaTouchSell = (touch14 and h1High >= h1EmaF and h1Close < h1EmaF) or (touch60 and h1High >= h1EmaS and h1Close < h1EmaS)

int  h1BarTime = request.security(syminfo.tickerid, "60", time, lookahead=barmerge.lookahead_off)
bool newH1Bar  = ta.change(h1BarTime) != 0
var int h1Count = 0
if newH1Bar
    h1Count += 1

// ============================================================================
// M15 DATA — states: realtime / events: confirmed
// ============================================================================
[m15AboveMid, m15BelowMid] = request.security(
     syminfo.tickerid, "15",
     [ta.sma(ta.rsi(close, rsiPeriod), pricePer) > ta.sma(ta.rsi(close, rsiPeriod), bandLen),
      ta.sma(ta.rsi(close, rsiPeriod), pricePer) < ta.sma(ta.rsi(close, rsiPeriod), bandLen)],
     lookahead=barmerge.lookahead_off)

[m15CrossUpSlowRaw, m15CrossDnSlowRaw] = request.security(
     syminfo.tickerid, "15",
     [ta.crossover(ta.sma(ta.rsi(close, rsiPeriod), pricePer),
                   ta.sma(ta.rsi(close, rsiPeriod), slowPer))[1],
      ta.crossunder(ta.sma(ta.rsi(close, rsiPeriod), pricePer),
                    ta.sma(ta.rsi(close, rsiPeriod), slowPer))[1]],
     lookahead=barmerge.lookahead_on)

int  m15BarTime = request.security(syminfo.tickerid, "15", time, lookahead=barmerge.lookahead_off)
bool newM15Bar  = ta.change(m15BarTime) != 0
bool m15CrossUpSlow = newM15Bar and m15CrossUpSlowRaw
bool m15CrossDnSlow = newM15Bar and m15CrossDnSlowRaw

var bool m15CrossDnPending = false
var bool m15CrossUpPending = false
if m15CrossDnSlow
    m15CrossDnPending := true
if m15CrossUpSlow
    m15CrossUpPending := true

// ============================================================================
// M5 TDI — LOCAL
// ============================================================================
float m5Rsi   = ta.rsi(close, rsiPeriod)
float m5Price = ta.sma(m5Rsi, pricePer)
float m5Slow  = ta.sma(m5Rsi, slowPer)

bool m5CrossUpSlow = m5Price > m5Slow and m5Price[1] <= m5Slow[1]
bool m5CrossDnSlow = m5Price < m5Slow and m5Price[1] >= m5Slow[1]

// ============================================================================
// SHARED CONDITIONS
// ============================================================================
bool isTrending = minEmaDist <= 0 or useEmaDist >= minEmaDist
bool inSession = not na(time(timeframe.period, sessionTime, "Asia/Bangkok"))

// ============================================================================
// ชุด A — Standard
// ============================================================================
var bool  buyArmedA     = false
var bool  sellArmedA    = false
var int   buyArmedA_at  = 0
var int   sellArmedA_at = 0
var bool  buyStep3A     = false
var bool  sellStep3A    = false

if not tdiBuyA
    buyArmedA := false
    buyStep3A := false
if not tdiSellA
    sellArmedA := false
    sellStep3A := false

if newH1Bar and buyArmedA and (h1Count - buyArmedA_at) > 1 and h1Close < h1Open
    buyArmedA := false
    buyStep3A := false
if newH1Bar and sellArmedA and (h1Count - sellArmedA_at) > 1 and h1Close > h1Open
    sellArmedA := false
    sellStep3A := false

if buyArmedA and (h1Count - buyArmedA_at) >= armedTimeout
    buyArmedA := false
    buyStep3A := false
if sellArmedA and (h1Count - sellArmedA_at) >= armedTimeout
    sellArmedA := false
    sellStep3A := false

if newH1Bar and not buyArmedA and tdiBuyA and emaTouchBuy
    buyArmedA    := true
    buyArmedA_at := h1Count - 1
if newH1Bar and not sellArmedA and tdiSellA and emaTouchSell
    sellArmedA    := true
    sellArmedA_at := h1Count - 1

if buyArmedA and m15BelowMid and not buyStep3A
    buyStep3A := true
if sellArmedA and m15AboveMid and not sellStep3A
    sellStep3A := true

if buyStep3A and not m15BelowMid
    buyStep3A := false
if sellStep3A and not m15AboveMid
    sellStep3A := false

// ============================================================================
// ชุด B — Early
// ============================================================================
var bool  buyB_step1     = false
var bool  sellB_step1    = false
var bool  buyArmedB      = false
var bool  sellArmedB     = false
var int   buyArmedB_at   = 0
var int   sellArmedB_at  = 0
var bool  buyStep3B      = false
var bool  sellStep3B     = false

if usePrice > useMid
    buyB_step1 := false
    buyArmedB  := false
    buyStep3B  := false
    m15CrossDnPending := false
if usePrice < useMid
    sellB_step1 := false
    sellArmedB  := false
    sellStep3B  := false
    m15CrossUpPending := false

if newH1Bar and buyArmedB and (h1Count - buyArmedB_at) > 1 and h1Close < h1Open
    buyArmedB := false
    buyStep3B := false
    m15CrossDnPending := false
if newH1Bar and sellArmedB and (h1Count - sellArmedB_at) > 1 and h1Close > h1Open
    sellArmedB := false
    sellStep3B := false
    m15CrossUpPending := false

if buyArmedB and (h1Count - buyArmedB_at) >= armedTimeout
    buyArmedB := false
    buyStep3B := false
    m15CrossDnPending := false
if sellArmedB and (h1Count - sellArmedB_at) >= armedTimeout
    sellArmedB := false
    sellStep3B := false
    m15CrossUpPending := false

if newH1Bar and usePrice < useMid and usePrice > earlyMinRsi and priceCrossUpSlow
    buyB_step1 := true
if newH1Bar and usePrice > useMid and usePrice < (100 - earlyMinRsi) and priceCrossDnSlow
    sellB_step1 := true

if newH1Bar and not buyArmedB and buyB_step1 and emaTouchBuy
    buyArmedB    := true
    buyArmedB_at := h1Count - 1
if newH1Bar and not sellArmedB and sellB_step1 and emaTouchSell
    sellArmedB    := true
    sellArmedB_at := h1Count - 1

if buyArmedB and m15AboveMid and m15CrossDnPending and not buyStep3B
    buyStep3B := true
    m15CrossDnPending := false
if sellArmedB and m15BelowMid and m15CrossUpPending and not sellStep3B
    sellStep3B := true
    m15CrossUpPending := false

// ============================================================================
// PB SIGNAL
// ============================================================================
bool pbBuyA  = inSession and enableA and buyBias  and isTrending and buyStep3A  and m5CrossUpSlow
bool pbSellA = inSession and enableA and sellBias and isTrending and sellStep3A and m5CrossDnSlow
bool pbBuyB  = inSession and enableB and buyBias  and isTrending and buyStep3B  and m5CrossUpSlow
bool pbSellB = inSession and enableB and sellBias and isTrending and sellStep3B and m5CrossDnSlow

if pbBuyA or pbBuyB
    buyArmedA  := false
    buyArmedB  := false
    buyStep3A  := false
    buyStep3B  := false
    buyB_step1 := false
    m15CrossDnPending := false
if pbSellA or pbSellB
    sellArmedA  := false
    sellArmedB  := false
    sellStep3A  := false
    sellStep3B  := false
    sellB_step1 := false
    m15CrossUpPending := false

bool newBuy  = pbBuyA or pbBuyB
bool newSell = pbSellA or pbSellB

// ============================================================================
// SWING SL + TP + POSITION SIZING
// ============================================================================
float swingLo = ta.lowest(low,  swingLen)
float swingHi = ta.highest(high, swingLen)

float buySL   = swingLo - slBuffer
float sellSL  = swingHi + slBuffer

float buySlDist  = math.abs(close - buySL)
float sellSlDist = math.abs(sellSL - close)

float buyTP  = close + buySlDist  * rrRatio
float sellTP = close - sellSlDist * rrRatio

float riskAmt = strategy.equity * riskPct / 100

float tickVal  = syminfo.pointvalue * syminfo.mintick
float buyQty   = buySlDist  > 0 and tickVal > 0 ? math.max(riskAmt / (buySlDist  / syminfo.mintick * tickVal), 0.01) : na
float sellQty  = sellSlDist > 0 and tickVal > 0 ? math.max(riskAmt / (sellSlDist / syminfo.mintick * tickVal), 0.01) : na

// ============================================================================
// STRATEGY EXECUTION
// ============================================================================
if newBuy and not na(buyQty) and buySlDist > 0
    strategy.entry("PB Buy", strategy.long, qty=buyQty)
    strategy.exit("PB Buy SL/TP", "PB Buy", stop=buySL, limit=buyTP)

if newSell and not na(sellQty) and sellSlDist > 0
    strategy.entry("PB Sell", strategy.short, qty=sellQty)
    strategy.exit("PB Sell SL/TP", "PB Sell", stop=sellSL, limit=sellTP)

// ============================================================================
// PLOTS
// ============================================================================
bool inLong  = strategy.position_size > 0
bool inShort = strategy.position_size < 0
plot(showSlTp and inLong  ? buySL  : na, "Buy SL",  color=color.new(#ef5350, 0), linewidth=1, style=plot.style_linebr)
plot(showSlTp and inLong  ? buyTP  : na, "Buy TP",  color=color.new(#26a69a, 0), linewidth=1, style=plot.style_linebr)
plot(showSlTp and inShort ? sellSL : na, "Sell SL", color=color.new(#ef5350, 0), linewidth=1, style=plot.style_linebr)
plot(showSlTp and inShort ? sellTP : na, "Sell TP", color=color.new(#26a69a, 0), linewidth=1, style=plot.style_linebr)

plotshape(newBuy,  title="PB Buy",  style=shape.triangleup,   location=location.belowbar, color=#26a69a, size=size.small)
plotshape(newSell, title="PB Sell", style=shape.triangledown, location=location.abovebar, color=#ef5350, size=size.small)
