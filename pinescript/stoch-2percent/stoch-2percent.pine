//@version=6
indicator("Auto Fibo Stoch", overlay = true, max_lines_count = 500, max_labels_count = 500)

// ─────────────────────────────────────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────────────────────────────────────

// ── 📊 Multi-TF Trend ──────────────────────────────────────────────────────
grpMTF       = "📊 Multi-TF Trend"
i_dayEnabled = input.bool(false, "Day",  group = grpMTF)
i_h4Enabled  = input.bool(false, "H4",   group = grpMTF)
i_h1Enabled  = input.bool(false, "H1",   group = grpMTF)
i_m15Enabled = input.bool(true,  "M15",  group = grpMTF)
i_m5Enabled  = input.bool(false, "M5",   group = grpMTF)
i_m1Enabled  = input.bool(false, "M1",   group = grpMTF)

// ── ⚙️ Stochastic ─────────────────────────────────────────────────────────
grpCore    = "⚙️ Stochastic"
i_kPeriod  = input.int(9,   "K Period",  minval = 1,  group = grpCore)
i_slowing  = input.int(3,   "Slowing",   minval = 1,  group = grpCore)
i_ovsLevel = input.int(20,  "OVS Level", minval = 1,  maxval = 49, group = grpCore)
i_ovbLevel = input.int(80,  "OVB Level", minval = 51, maxval = 99, group = grpCore)

// ── 📍 RSI Cut ────────────────────────────────────────────────────────────
grpRsiCut    = "📍 RSI Cut"
i_rsiCutEnabled = input.bool(true,  "เปิดใช้ RSI Cut",  group = grpRsiCut)
i_rsiPeriod     = input.int(14,     "RSI Period",       minval = 1, group = grpRsiCut)
i_rsiOvsLevel   = input.int(30,     "RSI OVS Level",    minval = 1,  maxval = 49, group = grpRsiCut)
i_rsiOvbLevel   = input.int(70,     "RSI OVB Level",    minval = 51, maxval = 99, group = grpRsiCut)

// ── 📍 EMA ────────────────────────────────────────────────────────────────
grpEMA     = "📍 EMA"
i_emaFast  = input.int(14, "Fast EMA",  minval = 1, group = grpEMA)
i_emaSlow  = input.int(60, "Slow EMA",  minval = 1, group = grpEMA)
i_showEMA  = input.bool(true, "แสดงเส้น EMA", group = grpEMA)
i_showEMAbg = input.bool(true, "แสดงพื้นหลัง EMA Cross", group = grpEMA)

// ── 📊 แสดงผล ─────────────────────────────────────────────────────────────
grpDisplay = "📊 แสดงผล"
i_showMarkers = input.bool(true,  "แสดงจุด OVS/OVB",      group = grpDisplay)
i_maxMarkers  = input.int(30, "จำนวนจุดสูงสุด (คู่)",    minval = 5, maxval = 100, group = grpDisplay)
i_showTrend   = input.bool(true, "แสดงป้ายเทรน (UP/DN)",  group = grpDisplay)
i_showZones   = input.bool(false, "แสดงพื้นหลังโซน OVS/OVB", group = grpDisplay)
i_showPattern = input.bool(false, "แสดงเส้น Flag Pattern", group = grpDisplay)
i_pivotLen    = input.int(2, "Pivot Length (Flag)",       minval = 1, maxval = 5, group = grpDisplay)

// ── 🎨 สี ─────────────────────────────────────────────────────────────────
grpColors  = "🎨 สี"
i_dayCol     = input.color(color.new(#AB47BC, 10), "Day",  inline = "cTF1", group = grpColors)
i_h4Col      = input.color(color.new(#26C6DA, 10), "H4",   inline = "cTF1", group = grpColors)
i_h1Col      = input.color(color.new(#66BB6A, 10), "H1",   inline = "cTF1", group = grpColors)
i_m15Col     = input.color(color.new(#FFA726, 10), "M15",  inline = "cTF2", group = grpColors)
i_m5Col      = input.color(color.new(#E040FB, 10), "M5",   inline = "cTF2", group = grpColors)
i_m1Col      = input.color(color.new(#80CBC4, 10), "M1",   inline = "cTF2", group = grpColors)

// ─────────────────────────────────────────────────────────────────────────────
// Constants
// ─────────────────────────────────────────────────────────────────────────────

var int SM_WAIT_OVS = 0
var int SM_WAIT_OVB = 1

// ─────────────────────────────────────────────────────────────────────────────
// UDT: TFEngine
// ─────────────────────────────────────────────────────────────────────────────

type TFEngine
    int     sm = 0
    float   ovsLo = na
    float   ovbHi = na
    float   prevOvsLo = na
    float   prevOvbHi = na
    int     trend = 0
    string  tfTag = ""
    color   col
    int     prevBarT = na
    float   cacheK = na
    float   cacheH = na
    float   cacheL = na
    float   cacheC = na

// ─────────────────────────────────────────────────────────────────────────────
// Stochastic + RSI (chart TF)
// ─────────────────────────────────────────────────────────────────────────────

kRaw = ta.stoch(close, high, low, i_kPeriod)
kVal = ta.sma(kRaw, i_slowing)

inOvs = kVal < i_ovsLevel
inOvb = kVal > i_ovbLevel

rsiRaw = ta.rsi(close, i_rsiPeriod)
rsiInOvs = rsiRaw < i_rsiOvsLevel
rsiInOvb = rsiRaw > i_rsiOvbLevel

// ─────────────────────────────────────────────────────────────────────────────
// TF Helpers
// ─────────────────────────────────────────────────────────────────────────────

formatTF(string tf) =>
    result = switch tf
        "1"    => "M1"
        "3"    => "M3"
        "5"    => "M5"
        "15"   => "M15"
        "30"   => "M30"
        "45"   => "M45"
        "60"   => "H1"
        "120"  => "H2"
        "180"  => "H3"
        "240"  => "H4"
        "D"    => "Day"
        "1D"   => "Day"
        "W"    => "Week"
        "1W"   => "Week"
        "M"    => "Month"
        "1M"   => "Month"
        => tf
    result

mainTFTag = formatTF(timeframe.period)

// ─────────────────────────────────────────────────────────────────────────────
// Multi-TF Data Fetching
// ─────────────────────────────────────────────────────────────────────────────

[rsK_d,  rsH_d,  rsL_d,  rsC_d,  rsT_d]  = request.security(syminfo.tickerid, "D",   [kVal, high, low, close, time])
[rsK_4h, rsH_4h, rsL_4h, rsC_4h, rsT_4h] = request.security(syminfo.tickerid, "240", [kVal, high, low, close, time])
[rsK_1h, rsH_1h, rsL_1h, rsC_1h, rsT_1h] = request.security(syminfo.tickerid, "60",  [kVal, high, low, close, time])
[rsK_15, rsH_15, rsL_15, rsC_15, rsT_15]  = request.security(syminfo.tickerid, "15",  [kVal, high, low, close, time])
[rsK_5,  rsH_5,  rsL_5,  rsC_5,  rsT_5]   = request.security(syminfo.tickerid, "5",   [kVal, high, low, close, time])
[rsK_1m, rsH_1m, rsL_1m, rsC_1m, rsT_1m]  = request.security(syminfo.tickerid, "1",   [kVal, high, low, close, time])

[ltH_d,  ltL_d,  ltC_d,  ltK_d,  ltT_d]  = request.security_lower_tf(syminfo.tickerid, "D",   [high, low, close, ta.sma(ta.stoch(close, high, low, i_kPeriod), i_slowing), time], ignore_invalid_timeframe = true)
[ltH_4h, ltL_4h, ltC_4h, ltK_4h, ltT_4h] = request.security_lower_tf(syminfo.tickerid, "240", [high, low, close, ta.sma(ta.stoch(close, high, low, i_kPeriod), i_slowing), time], ignore_invalid_timeframe = true)
[ltH_1h, ltL_1h, ltC_1h, ltK_1h, ltT_1h] = request.security_lower_tf(syminfo.tickerid, "60",  [high, low, close, ta.sma(ta.stoch(close, high, low, i_kPeriod), i_slowing), time], ignore_invalid_timeframe = true)
[ltH_15, ltL_15, ltC_15, ltK_15, ltT_15]  = request.security_lower_tf(syminfo.tickerid, "15",  [high, low, close, ta.sma(ta.stoch(close, high, low, i_kPeriod), i_slowing), time], ignore_invalid_timeframe = true)
[ltH_5,  ltL_5,  ltC_5,  ltK_5,  ltT_5]   = request.security_lower_tf(syminfo.tickerid, "5",   [high, low, close, ta.sma(ta.stoch(close, high, low, i_kPeriod), i_slowing), time], ignore_invalid_timeframe = true)
[ltH_1m, ltL_1m, ltC_1m, ltK_1m, ltT_1m]  = request.security_lower_tf(syminfo.tickerid, "1",   [high, low, close, ta.sma(ta.stoch(close, high, low, i_kPeriod), i_slowing), time], ignore_invalid_timeframe = true)

// ─────────────────────────────────────────────────────────────────────────────
// TFEngine Methods
// ─────────────────────────────────────────────────────────────────────────────

method tick(TFEngine this, float _h, float _l, float _c, float _k, int _t) =>
    _isOvs = _k < i_ovsLevel
    _isOvb = _k > i_ovbLevel

    if this.sm == 0
        if na(this.ovsLo) or _l < this.ovsLo
            this.ovsLo := _l
            this.ovbHi := _h
        else
            if na(this.ovbHi) or _h > this.ovbHi
                this.ovbHi := _h
        if _isOvb and not na(this.ovsLo)
            _sLo  = this.ovsLo
            _isHL = not na(this.prevOvsLo) and _sLo > this.prevOvsLo
            _isLL = not na(this.prevOvsLo) and _sLo < this.prevOvsLo
            if not na(this.prevOvsLo)
                if this.trend == 0 and _isHL
                    this.trend := 2
                else if this.trend == 0 and _isLL
                    this.trend := -1
                else if this.trend == -1 and _isHL
                    this.trend := 2
                else if this.trend == 1 and _isLL
                    this.trend := -2
                else if this.trend == -2 and _isLL
                    this.trend := -1
                else if this.trend == -2 and _isHL
                    this.trend := 1
            this.prevOvsLo := _sLo
            this.sm    := 1
            this.ovsLo := na

    else if this.sm == 1
        if na(this.ovbHi) or _h > this.ovbHi
            this.ovbHi := _h
            this.ovsLo := _l
        else
            if na(this.ovsLo) or _l < this.ovsLo
                this.ovsLo := _l
        if _isOvs
            _fHi = this.ovbHi
            if not na(this.prevOvbHi)
                _isHH = _fHi > this.prevOvbHi
                _isLH = _fHi < this.prevOvbHi
                if this.trend == 1 and _isLH
                    this.trend := -2
                else if this.trend == -1 and _isHH
                    this.trend := 2
                else if this.trend == 2 and _isHH
                    this.trend := 1
                else if this.trend == 2 and _isLH
                    this.trend := -1
                else if this.trend == -2 and _isLH
                    this.trend := -1
                else if this.trend == -2 and _isHH
                    this.trend := 1
            this.prevOvbHi := _fHi
            this.sm    := 0
            this.ovbHi := na

method feedLowerTF(TFEngine this, float[] _aH, float[] _aL, float[] _aC, float[] _aK, int[] _aT) =>
    for j = 0 to array.size(_aH) - 1
        this.tick(array.get(_aH, j), array.get(_aL, j), array.get(_aC, j), array.get(_aK, j), array.get(_aT, j))

method feedHigherTF(TFEngine this, float _k, float _h, float _l, float _c, int _t, bool isLast) =>
    if not na(_t)
        if na(this.prevBarT)
            this.prevBarT := _t
        else if _t != this.prevBarT
            this.tick(this.cacheH, this.cacheL, this.cacheC, this.cacheK, this.prevBarT)
            this.prevBarT := _t
        this.cacheK := _k
        this.cacheH := _h
        this.cacheL := _l
        this.cacheC := _c
        if isLast and not na(this.cacheK)
            this.tick(this.cacheH, this.cacheL, this.cacheC, this.cacheK, this.prevBarT)

// ─────────────────────────────────────────────────────────────────────────────
// TFEngine Instances
// ─────────────────────────────────────────────────────────────────────────────

var TFEngine engDay = TFEngine.new(tfTag = "Day", col = i_dayCol)
var TFEngine engH4  = TFEngine.new(tfTag = "H4",  col = i_h4Col)
var TFEngine engH1  = TFEngine.new(tfTag = "H1",  col = i_h1Col)
var TFEngine engM15 = TFEngine.new(tfTag = "M15", col = i_m15Col)
var TFEngine engM5  = TFEngine.new(tfTag = "M5",  col = i_m5Col)
var TFEngine engM1  = TFEngine.new(tfTag = "M1",  col = i_m1Col)

// ─────────────────────────────────────────────────────────────────────────────
// Main SM State Variables (chart TF)
// ─────────────────────────────────────────────────────────────────────────────

var int   smState = SM_WAIT_OVS
var float ovsLow  = na
var int   ovsBar  = na
var float ovbHigh = na
var int   ovbBar  = na

var label curOvsLbl = na
var label curOvbLbl = na
var array<label> allMarkers = array.new<label>()

var float confirmedOvbHigh    = na
var int   confirmedOvbBar    = na
var float prevConfirmedOvsLow = na
var int   prevConfirmedOvsBar = na
var int   trend        = 0
var float prevOvbHigh  = na
var array<label> trendLabels = array.new<label>()


var float patPivHi    = na
var int   patPivHiBar = na
var float patPivLo    = na
var int   patPivLoBar = na
var array<line> patLines = array.new<line>()

// ─────────────────────────────────────────────────────────────────────────────
// RSI Mountain Cut State Machine
// ─────────────────────────────────────────────────────────────────────────────

var int  RSI_WAIT_FIRST_OVS  = 0
var int  RSI_WAIT_OVB        = 1
var int  RSI_WAIT_SECOND_OVS = 2

var int   rsiCutState = RSI_WAIT_FIRST_OVS
var bool  rsiCutBar   = false

if i_rsiCutEnabled
    rsiCutBar := false
    if rsiCutState == RSI_WAIT_FIRST_OVS and rsiInOvs
        rsiCutState := RSI_WAIT_OVB
    else if rsiCutState == RSI_WAIT_OVB and rsiInOvb
        rsiCutState := RSI_WAIT_SECOND_OVS
    else if rsiCutState == RSI_WAIT_SECOND_OVS and rsiInOvs
        rsiCutBar  := true
        rsiCutState := RSI_WAIT_FIRST_OVS

bgcolor(i_rsiCutEnabled and rsiCutBar ? color.new(color.purple, 70) : na, title = "RSI CUT")

// ─────────────────────────────────────────────────────────────────────────────
// Pivot Detection
// ─────────────────────────────────────────────────────────────────────────────

pivHi = ta.pivothigh(high, i_pivotLen, i_pivotLen)
pivLo = ta.pivotlow(low, i_pivotLen, i_pivotLen)

// ─────────────────────────────────────────────────────────────────────────────
// Main State Machine (chart TF)
// ─────────────────────────────────────────────────────────────────────────────

switch smState
    SM_WAIT_OVS =>
        if not na(pivHi) and na(patPivHi)
            patPivHi    := pivHi
            patPivHiBar := bar_index - i_pivotLen
        if not na(pivLo) and na(patPivLo)
            patPivLo    := pivLo
            patPivLoBar := bar_index - i_pivotLen

        if na(ovsLow) or low < ovsLow
            ovsLow  := low
            ovsBar  := bar_index
            ovbHigh := high
            ovbBar  := bar_index
            if i_showMarkers
                if na(curOvsLbl)
                    curOvsLbl := label.new(bar_index, low, "⏳ S",
                         style = label.style_label_up, color = color.new(color.aqua, 30),
                         textcolor = color.white, size = size.small)
                else
                    label.set_x(curOvsLbl, bar_index)
                    label.set_y(curOvsLbl, low)
        else
            if na(ovbHigh) or high > ovbHigh
                ovbHigh := high
                ovbBar  := bar_index

        if inOvb and not na(ovsLow)
            savedOvsLow = ovsLow
            savedOvsBar = ovsBar

            if not na(curOvsLbl)
                label.set_text(curOvsLbl, "S")
                label.set_style(curOvsLbl, label.style_diamond)
                label.set_color(curOvsLbl, color.aqua)
                label.set_textcolor(curOvsLbl, color.aqua)
                label.set_size(curOvsLbl, size.tiny)
                array.push(allMarkers, curOvsLbl)
                curOvsLbl := na

            if not na(prevConfirmedOvsLow)
                isHL = savedOvsLow > prevConfirmedOvsLow
                isLL = savedOvsLow < prevConfirmedOvsLow
                if trend == 0 and isHL
                    trend := 2
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "⚠HL",
                             style = label.style_label_up, color = color.new(color.yellow, 10),
                             textcolor = color.black, size = size.small))
                else if trend == 0 and isLL
                    trend := -1
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "DN",
                             style = label.style_label_up, color = color.new(color.red, 10),
                             textcolor = color.white, size = size.normal))
                else if trend == -1 and isHL
                    trend := 2
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "⚠HL",
                             style = label.style_label_up, color = color.new(color.yellow, 10),
                             textcolor = color.black, size = size.small))
                else if trend == 1 and isLL
                    trend := -2
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "⚠LL",
                             style = label.style_label_up, color = color.new(color.yellow, 10),
                             textcolor = color.black, size = size.small))
                else if trend == -2 and isLL
                    trend := -1
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "DN",
                             style = label.style_label_up, color = color.new(color.red, 10),
                             textcolor = color.white, size = size.normal))
                else if trend == -2 and isHL
                    trend := 1
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "UP",
                             style = label.style_label_up, color = color.new(color.green, 10),
                             textcolor = color.white, size = size.normal))

            prevConfirmedOvsLow := savedOvsLow
            prevConfirmedOvsBar := savedOvsBar

            if i_showPattern and not na(confirmedOvbHigh) and not na(confirmedOvbBar)
                if not na(patPivHi) and not na(patPivHiBar)
                    upperLine = line.new(confirmedOvbBar, confirmedOvbHigh, patPivHiBar, patPivHi,
                         color = color.new(color.white, 20), width = 1, style = line.style_solid, extend = extend.right)
                    array.push(patLines, upperLine)
                if not na(patPivLo) and not na(patPivLoBar)
                    lowerLine = line.new(patPivLoBar, patPivLo, savedOvsBar, savedOvsLow,
                         color = color.new(color.white, 20), width = 1, style = line.style_solid, extend = extend.right)
                    array.push(patLines, lowerLine)
                while array.size(patLines) > 10
                    line.delete(array.get(patLines, 0))
                    array.remove(patLines, 0)

            patPivHi    := na
            patPivHiBar := na
            patPivLo    := na
            patPivLoBar := na

            smState := SM_WAIT_OVB
            ovsLow  := na
            ovsBar  := na
            if i_showMarkers
                curOvbLbl := label.new(ovbBar, ovbHigh, "⏳ B",
                     style = label.style_label_down, color = color.new(color.orange, 30),
                     textcolor = color.white, size = size.small)

    SM_WAIT_OVB =>
        if na(ovbHigh) or high > ovbHigh
            ovbHigh := high
            ovbBar  := bar_index
            ovsLow  := low
            ovsBar  := bar_index
            if i_showMarkers
                if na(curOvbLbl)
                    curOvbLbl := label.new(bar_index, high, "⏳ B",
                         style = label.style_label_down, color = color.new(color.orange, 30),
                         textcolor = color.white, size = size.small)
                else
                    label.set_x(curOvbLbl, bar_index)
                    label.set_y(curOvbLbl, high)
        else
            if na(ovsLow) or low < ovsLow
                ovsLow := low
                ovsBar := bar_index

        if inOvs
            finalOvbHigh = ovbHigh
            finalOvbBar  = ovbBar

            if not na(prevOvbHigh)
                isHH = finalOvbHigh > prevOvbHigh
                isLH = finalOvbHigh < prevOvbHigh
                if trend == 1 and isLH
                    trend := -2
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "⚠LH",
                             style = label.style_label_down, color = color.new(color.yellow, 10),
                             textcolor = color.black, size = size.small))
                else if trend == -1 and isHH
                    trend := 2
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "⚠HH",
                             style = label.style_label_down, color = color.new(color.yellow, 10),
                             textcolor = color.black, size = size.small))
                else if trend == 2 and isHH
                    trend := 1
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "UP",
                             style = label.style_label_down, color = color.new(color.green, 10),
                             textcolor = color.white, size = size.normal))
                else if trend == 2 and isLH
                    trend := -1
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "DN",
                             style = label.style_label_down, color = color.new(color.red, 10),
                             textcolor = color.white, size = size.normal))
                else if trend == -2 and isLH
                    trend := -1
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "DN",
                             style = label.style_label_down, color = color.new(color.red, 10),
                             textcolor = color.white, size = size.normal))
                else if trend == -2 and isHH
                    trend := 1
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "UP",
                             style = label.style_label_down, color = color.new(color.green, 10),
                             textcolor = color.white, size = size.normal))

            prevOvbHigh      := finalOvbHigh
            confirmedOvbHigh := finalOvbHigh
            confirmedOvbBar  := finalOvbBar

            if not na(curOvbLbl)
                label.set_text(curOvbLbl, "B")
                label.set_style(curOvbLbl, label.style_diamond)
                label.set_color(curOvbLbl, color.orange)
                label.set_textcolor(curOvbLbl, color.orange)
                label.set_size(curOvbLbl, size.tiny)
                array.push(allMarkers, curOvbLbl)
                curOvbLbl := na

            patPivHi    := na
            patPivHiBar := na
            patPivLo    := na
            patPivLoBar := na

            smState := SM_WAIT_OVS
            ovbHigh := na
            ovbBar  := na
            if i_showMarkers
                curOvsLbl := label.new(ovsBar, ovsLow, "⏳ S",
                     style = label.style_label_up, color = color.new(color.aqua, 30),
                     textcolor = color.white, size = size.small)

// ─────────────────────────────────────────────────────────────────────────────
// Multi-TF Engine Processing
// ─────────────────────────────────────────────────────────────────────────────

chartSec   = timeframe.in_seconds()
isChartDay = chartSec == timeframe.in_seconds("D")
isChartH4  = chartSec == timeframe.in_seconds("240")
isChartH1  = chartSec == timeframe.in_seconds("60")
isChartM15 = chartSec == timeframe.in_seconds("15")
isChartM5  = chartSec == timeframe.in_seconds("5")
isChartM1  = chartSec == timeframe.in_seconds("1")

ltSz_d  = not na(ltH_d)  ? array.size(ltH_d)  : 0
ltSz_4h = not na(ltH_4h) ? array.size(ltH_4h) : 0
ltSz_1h = not na(ltH_1h) ? array.size(ltH_1h) : 0
ltSz_15 = not na(ltH_15) ? array.size(ltH_15) : 0
ltSz_5  = not na(ltH_5)  ? array.size(ltH_5)  : 0
ltSz_1m = not na(ltH_1m) ? array.size(ltH_1m) : 0

if i_dayEnabled
    if isChartDay
        engDay.tick(high, low, close, kVal, time)
    else if ltSz_d > 0
        engDay.feedLowerTF(ltH_d, ltL_d, ltC_d, ltK_d, ltT_d)
    else
        engDay.feedHigherTF(rsK_d, rsH_d, rsL_d, rsC_d, rsT_d, barstate.islast)

if i_h4Enabled
    if isChartH4
        engH4.tick(high, low, close, kVal, time)
    else if ltSz_4h > 0
        engH4.feedLowerTF(ltH_4h, ltL_4h, ltC_4h, ltK_4h, ltT_4h)
    else
        engH4.feedHigherTF(rsK_4h, rsH_4h, rsL_4h, rsC_4h, rsT_4h, barstate.islast)

if i_h1Enabled
    if isChartH1
        engH1.tick(high, low, close, kVal, time)
    else if ltSz_1h > 0
        engH1.feedLowerTF(ltH_1h, ltL_1h, ltC_1h, ltK_1h, ltT_1h)
    else
        engH1.feedHigherTF(rsK_1h, rsH_1h, rsL_1h, rsC_1h, rsT_1h, barstate.islast)

if i_m15Enabled
    if isChartM15
        engM15.tick(high, low, close, kVal, time)
    else if ltSz_15 > 0
        engM15.feedLowerTF(ltH_15, ltL_15, ltC_15, ltK_15, ltT_15)
    else
        engM15.feedHigherTF(rsK_15, rsH_15, rsL_15, rsC_15, rsT_15, barstate.islast)

if i_m5Enabled
    if isChartM5
        engM5.tick(high, low, close, kVal, time)
    else if ltSz_5 > 0
        engM5.feedLowerTF(ltH_5, ltL_5, ltC_5, ltK_5, ltT_5)
    else
        engM5.feedHigherTF(rsK_5, rsH_5, rsL_5, rsC_5, rsT_5, barstate.islast)

if i_m1Enabled
    if isChartM1
        engM1.tick(high, low, close, kVal, time)
    else if ltSz_1m > 0
        engM1.feedLowerTF(ltH_1m, ltL_1m, ltC_1m, ltK_1m, ltT_1m)
    else
        engM1.feedHigherTF(rsK_1m, rsH_1m, rsL_1m, rsC_1m, rsT_1m, barstate.islast)

// ─────────────────────────────────────────────────────────────────────────────
// Cleanup old markers
// ─────────────────────────────────────────────────────────────────────────────

while array.size(allMarkers) > i_maxMarkers * 2
    label.delete(array.get(allMarkers, 0))
    array.remove(allMarkers, 0)

while array.size(trendLabels) > 20
    label.delete(array.get(trendLabels, 0))
    array.remove(trendLabels, 0)

// ─────────────────────────────────────────────────────────────────────────────
// Zone Visualization
// ─────────────────────────────────────────────────────────────────────────────

bgcolor(i_showZones and inOvs ? color.new(color.blue, 88) : na, title = "OVS Zone")
bgcolor(i_showZones and inOvb ? color.new(color.red, 88) : na,  title = "OVB Zone")

// ─────────────────────────────────────────────────────────────────────────────
// EMA 14 / 60 + Cross Background
// ─────────────────────────────────────────────────────────────────────────────

emaFast = ta.ema(close, i_emaFast)
emaSlow = ta.ema(close, i_emaSlow)

pFast = plot(i_showEMA ? emaFast : na, "EMA Fast", color.new(color.yellow, 0), 2)
pSlow = plot(i_showEMA ? emaSlow : na, "EMA Slow", color.new(#FF9800, 0), 2)

cloudCol = emaFast > emaSlow ? color.new(color.green, 85) : color.new(color.red, 85)
fill(pFast, pSlow, i_showEMAbg ? cloudCol : na, title = "EMA Cloud")

// ─────────────────────────────────────────────────────────────────────────────
// Status Panel
// ─────────────────────────────────────────────────────────────────────────────

if barstate.islast
    var table statusTbl = table.new(position.bottom_right, 2, 12,
         bgcolor = color.new(#1E1E1E, 0), border_color = color.new(#333333, 0), border_width = 1,
         frame_color = color.new(#555555, 0), frame_width = 2)

    hSz = size.small
    vSz = size.small

    table.cell(statusTbl, 0, 0, "Chart TF", text_color = color.gray, text_size = hSz, text_halign = text.align_right)
    table.cell(statusTbl, 1, 0, mainTFTag, text_color = color.white, text_size = vSz, text_halign = text.align_left)

    trendTxt = trend == 1 ? "🟢 UP" : trend == -1 ? "🔴 DN" : trend == 2 ? "🟡 ⚠HL" : trend == -2 ? "🟡 ⚠LH" : "⚪ –"
    trendCol = trend == 1 ? color.green : trend == -1 ? color.red : trend == 2 or trend == -2 ? color.yellow : color.gray
    table.cell(statusTbl, 0, 1, "เทรน", text_color = color.gray, text_size = hSz, text_halign = text.align_right)
    table.cell(statusTbl, 1, 1, trendTxt, text_color = trendCol, text_size = vSz, text_halign = text.align_left)

    smTxt = smState == SM_WAIT_OVS ? "🔻 OVS" : "🔺 OVB"
    smCol = smState == SM_WAIT_OVS ? color.aqua : color.orange
    table.cell(statusTbl, 0, 2, "Stoch", text_color = color.gray, text_size = hSz, text_halign = text.align_right)
    table.cell(statusTbl, 1, 2, smTxt, text_color = smCol, text_size = vSz, text_halign = text.align_left)

    emaTxt = emaFast > emaSlow ? "🟢 บวก" : "🔴 ลบ"
    emaCol = emaFast > emaSlow ? color.green : color.red
    table.cell(statusTbl, 0, 3, "EMA", text_color = color.gray, text_size = hSz, text_halign = text.align_right)
    table.cell(statusTbl, 1, 3, emaTxt, text_color = emaCol, text_size = vSz, text_halign = text.align_left)

    rowIdx = 4
    if i_dayEnabled
        _s1 = engDay.trend == 1 ? "▲ UP" : engDay.trend == -1 ? "▼ DN" : engDay.trend == 2 ? "⚠ HL" : engDay.trend == -2 ? "⚠ LH" : "–"
        _c1 = engDay.trend == 1 ? color.green : engDay.trend == -1 ? color.red : engDay.trend == 2 or engDay.trend == -2 ? color.yellow : color.gray
        table.cell(statusTbl, 0, rowIdx, "Day", text_color = i_dayCol, text_size = hSz, text_halign = text.align_right)
        table.cell(statusTbl, 1, rowIdx, _s1, text_color = _c1, text_size = vSz, text_halign = text.align_left)
        rowIdx += 1
    if i_h4Enabled
        _s2 = engH4.trend == 1 ? "▲ UP" : engH4.trend == -1 ? "▼ DN" : engH4.trend == 2 ? "⚠ HL" : engH4.trend == -2 ? "⚠ LH" : "–"
        _c2 = engH4.trend == 1 ? color.green : engH4.trend == -1 ? color.red : engH4.trend == 2 or engH4.trend == -2 ? color.yellow : color.gray
        table.cell(statusTbl, 0, rowIdx, "H4", text_color = i_h4Col, text_size = hSz, text_halign = text.align_right)
        table.cell(statusTbl, 1, rowIdx, _s2, text_color = _c2, text_size = vSz, text_halign = text.align_left)
        rowIdx += 1
    if i_h1Enabled
        _s3 = engH1.trend == 1 ? "▲ UP" : engH1.trend == -1 ? "▼ DN" : engH1.trend == 2 ? "⚠ HL" : engH1.trend == -2 ? "⚠ LH" : "–"
        _c3 = engH1.trend == 1 ? color.green : engH1.trend == -1 ? color.red : engH1.trend == 2 or engH1.trend == -2 ? color.yellow : color.gray
        table.cell(statusTbl, 0, rowIdx, "H1", text_color = i_h1Col, text_size = hSz, text_halign = text.align_right)
        table.cell(statusTbl, 1, rowIdx, _s3, text_color = _c3, text_size = vSz, text_halign = text.align_left)
        rowIdx += 1
    if i_m15Enabled
        _s4 = engM15.trend == 1 ? "▲ UP" : engM15.trend == -1 ? "▼ DN" : engM15.trend == 2 ? "⚠ HL" : engM15.trend == -2 ? "⚠ LH" : "–"
        _c4 = engM15.trend == 1 ? color.green : engM15.trend == -1 ? color.red : engM15.trend == 2 or engM15.trend == -2 ? color.yellow : color.gray
        table.cell(statusTbl, 0, rowIdx, "M15", text_color = i_m15Col, text_size = hSz, text_halign = text.align_right)
        table.cell(statusTbl, 1, rowIdx, _s4, text_color = _c4, text_size = vSz, text_halign = text.align_left)
        rowIdx += 1
    if i_m5Enabled
        _s5 = engM5.trend == 1 ? "▲ UP" : engM5.trend == -1 ? "▼ DN" : engM5.trend == 2 ? "⚠ HL" : engM5.trend == -2 ? "⚠ LH" : "–"
        _c5 = engM5.trend == 1 ? color.green : engM5.trend == -1 ? color.red : engM5.trend == 2 or engM5.trend == -2 ? color.yellow : color.gray
        table.cell(statusTbl, 0, rowIdx, "M5", text_color = i_m5Col, text_size = hSz, text_halign = text.align_right)
        table.cell(statusTbl, 1, rowIdx, _s5, text_color = _c5, text_size = vSz, text_halign = text.align_left)
        rowIdx += 1
    if i_m1Enabled
        _s6 = engM1.trend == 1 ? "▲ UP" : engM1.trend == -1 ? "▼ DN" : engM1.trend == 2 ? "⚠ HL" : engM1.trend == -2 ? "⚠ LH" : "–"
        _c6 = engM1.trend == 1 ? color.green : engM1.trend == -1 ? color.red : engM1.trend == 2 or engM1.trend == -2 ? color.yellow : color.gray
        table.cell(statusTbl, 0, rowIdx, "M1", text_color = i_m1Col, text_size = hSz, text_halign = text.align_right)
        table.cell(statusTbl, 1, rowIdx, _s6, text_color = _c6, text_size = vSz, text_halign = text.align_left)
        rowIdx += 1
