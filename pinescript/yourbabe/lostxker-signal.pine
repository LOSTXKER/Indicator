// LOSTXKER Signal
// TF-aware: M5 + H1 signals + M15 bar color & dashboard
//@version=6
indicator("LOSTXKER Signal", shorttitle="LX Signal", overlay=true, max_labels_count=500, max_boxes_count=500, max_lines_count=500, max_bars_back=500)

// ============================================================================
// ALERT TIME
// ============================================================================
string GRP_ALERT = "ALERT TIME"
bool   specTimeOn = input.bool(true,  "Specific Time Alert (On/Off)", group=GRP_ALERT)
int    alertTZ    = input.int(7,  "Time zone UTC+", minval=-12, maxval=14, group=GRP_ALERT)
int    startH     = input.int(7,  "Start Time", inline="st", group=GRP_ALERT)
int    startMin   = input.int(30, ":",           inline="st", group=GRP_ALERT)
int    endH       = input.int(1,  "End Time",   inline="et", group=GRP_ALERT)
int    endMin     = input.int(0,  ":",           inline="et", group=GRP_ALERT)

// ============================================================================
// NOTIFY (Webhook target)
// ============================================================================
string GRP_NOTIFY = "NOTIFY"
string alertTarget = input.string("LINE Proxy", "Webhook Target", options=["LINE Proxy", "Discord"], group=GRP_NOTIFY, tooltip="เลือกฟอร์แมต payload ให้ตรงกับ Webhook URL ที่ตั้งใน TradingView Alert\n• LINE Proxy → JSON สำหรับ line-webhook-proxy-one.vercel.app\n• Discord → {\"content\":\"...\"} ยิงตรงเข้า Discord Webhook URL")

// ============================================================================
// SIGNAL TIMEFRAMES
// ============================================================================
string GRP_TF = "SIGNAL TIMEFRAMES"
bool   sigOnM5 = input.bool(true, "Enable M5 Signals", group=GRP_TF)
bool   sigOnH1 = input.bool(true, "Enable H1 Signals", group=GRP_TF, tooltip="ใช้ logic เดียวกับ M5 (TDI cross + Fair Price + Powerful + HTF EMA60 filter)\nบน H1 ตัว HTF จะเทียบที่ EMA240 ของ H1 (≈ EMA60 ของ H4)")

// ============================================================================
// POWERFUL MODE (M5/H1)
// ============================================================================
string GRP_SW = "POWERFUL MODE (M5/H1)"
bool   powerfulOn    = input.bool(true, "Powerful Mode (block overextended)", group=GRP_SW, tooltip="กันสัญญาณเบรกเอาต์\n• Buy block: ราคาปิด > จุดสูงสุดของ N แท่งก่อน\n• Sell block: ราคาปิด < จุดต่ำสุดของ N แท่งก่อน")
int    powerLookback = input.int(11, "Powerful Lookback (bars)", minval=3, maxval=100, group=GRP_SW, tooltip="มองย้อนหลังกี่แท่งเพื่อหา peak / trough\n(ยิ่งสูง = ยิ่ง block ง่าย)")
bool   powerShowDot  = input.bool(false, "Show Blocked Signal Dot (ม่วง)", group=GRP_SW)
bool   powerShowRef  = input.bool(false, "Show Powerful Reference Level", group=GRP_SW, tooltip="โชว์เส้นม่วงระดับ peak/trough ที่ใช้เทียบ\n(เอาไว้ดูว่า block ถูกจุดมั้ย)")

// ============================================================================
// OPTIONAL FILTERS (M5/H1)
// ============================================================================
string GRP_OPT = "OPTIONAL (M5/H1)"
bool   htfFilterOn   = input.bool(true, "HTF EMA60 Filter (Toggle)", group=GRP_OPT, tooltip="บังคับไส้แท่งฝั่งเดียวกับเทรนด์ใหญ่\n• Buy: high > EMA60 ของ M15 (ไส้บนแตะ cyan)\n• Sell: low < EMA60 ของ M15 (ไส้ล่างแตะ cyan)\n\nปิด = รับสัญญาณแม้เทรนด์ HTF สวนทาง (ไวขึ้น แต่เสี่ยง counter-trend)")
bool   htfShow       = input.bool(false, "Show HTF EMA60 (cyan)", group=GRP_OPT, tooltip="โชว์เส้น cyan ที่ใช้เป็น HTF filter")
bool   fairPriceOn   = input.bool(true, "Fair Price (Toggle)", group=GRP_OPT)
int    fairLookback  = input.int(7, "Fair Price Lookback (bars)", minval=1, maxval=30, group=GRP_OPT, tooltip="ใน N แท่งล่าสุดต้องมีแท่งไหนสักแท่งที่ wick แตะ EMA8\n(pullback เคยแตะ EMA8)")
int    tdiDipLookback = input.int(10, "TDI Pullback Lookback (bars)", minval=2, maxval=50, group=GRP_OPT, tooltip="ใน N แท่งล่าสุดบน panel TDI\nต้องมี priceLine เคยดิ่งลง (Buy) / ดีดขึ้น (Sell) แตะกลุ่ม ruobsen\n• ต่ำ = เข้มขึ้น (pullback ต้องเพิ่งเกิด)\n• สูง = เบาลง")
bool   fairPriceShow = input.bool(false, "Show Fair Price (EMA8)", group=GRP_OPT, tooltip="โชว์เส้น EMA8 สีส้ม")
string flatEmaMode   = input.string("ON - Show", "Flat EMA Detect", options=["OFF", "ON - Hide", "ON - Show"], group=GRP_OPT, tooltip="จัดการสัญญาณตอน EMA ยังไม่กาง:\n• OFF = ไม่ทำอะไร\n• ON - Hide = ซ่อนสัญญาณ\n• ON - Show = โชว์ป้าย Buy/Sell สีส้ม")
float  flatThresh    = input.float(0.5, "Fan Spread (ATR units)", minval=0.1, maxval=5.0, step=0.1, group=GRP_OPT, tooltip="ระยะห่าง EMA8 กับ EMA60 เทียบเป็น ATR\nต่ำกว่าค่านี้ = EMA ยังไม่กาง\n• 0.7 = เข้ม (ส้มน้อย)\n• 1.0 = กลาง\n• 1.5 = หลวม (ส้มเยอะ)")

// ============================================================================
// BAR COLOR (M15 only)
// ============================================================================
string GRP_BAR = "BAR COLOR (M15)"
bool   barColorOn = input.bool(true, "Enable Bar Color", group=GRP_BAR)

// ============================================================================
// DASHBOARD (M15 only)
// ============================================================================
string GRP_DASH = "DASHBOARD (M15)"
bool   dashOn   = input.bool(true, "Dashboard Checklist", group=GRP_DASH)
string dashLoc  = input.string("Bottom Right", "Location", options=["Top Left", "Top Right", "Bottom Left", "Bottom Right"], group=GRP_DASH)
string dashSize = input.string("small", "Size", options=["small", "normal", "large"], group=GRP_DASH)

// ============================================================================
// TDI (must match lostxker-indicator.pine)
// ============================================================================
string GRP_TDI = "TDI (Match Indicator)"
int    rsiPeriod   = input.int(13,     "RSI Period",      minval=1, group=GRP_TDI)
int    bandLen     = input.int(31,     "Band Length",     minval=1, group=GRP_TDI)
int    pricePeriod = input.int(1,      "Price Period",    minval=1, group=GRP_TDI)
int    sentPeriod  = input.int(8,      "Sentiment Period (M15)", minval=1, group=GRP_TDI, tooltip="M15 Sentiment line")
int    sent1Period = input.int(6,      "รวบเส้น 1",        minval=1, group=GRP_TDI)
int    sent2Period = input.int(8,      "รวบเส้น 2",        minval=1, group=GRP_TDI)
int    sent3Period = input.int(9,      "รวบเส้น 3",        minval=1, group=GRP_TDI)

// ============================================================================
// TF DETECTION
// ============================================================================
bool isM5  = timeframe.period == "5"
bool isM15 = timeframe.period == "15"
bool isH1  = timeframe.period == "60"
bool isSignalTF = (isM5 and sigOnM5) or (isH1 and sigOnH1)

// ============================================================================
// EMA
// ============================================================================
ema8  = ta.ema(close, 8)
ema14 = ta.ema(close, 14)
ema60 = ta.ema(close, 60)

htfMult = switch timeframe.period
    "1"  => 5
    "3"  => 5
    "5"  => 3
    "15" => 4
    "30" => 2
    "60" => 4
    "240" => 6
    =>       1

float htfEma60 = ta.ema(close, 60 * htfMult)
float atrVal   = ta.atr(14)

bool ema8x14up = ta.crossover(ema8, ema14)
bool ema8x14dn = ta.crossunder(ema8, ema14)

var bool emaBull = false
if ema8x14up
    emaBull := true
if ema8x14dn
    emaBull := false

// ============================================================================
// TDI
// ============================================================================
rsiVal        = ta.rsi(close, rsiPeriod)
bbMa          = ta.sma(rsiVal, bandLen)
priceLine     = ta.sma(rsiVal, pricePeriod)
sentimentMain = ta.sma(rsiVal, sentPeriod)
sentiment1    = ta.sma(rsiVal, sent1Period)
sentiment2    = ta.sma(rsiVal, sent2Period)
sentiment3    = ta.sma(rsiVal, sent3Period)

// ============================================================================
// POWERFUL REFERENCE (peak/trough ใน N แท่ง ไม่รวมแท่งปัจจุบัน)
// ============================================================================
float powerRefHi = ta.highest(high, powerLookback)[1]
float powerRefLo = ta.lowest(low,   powerLookback)[1]

// ============================================================================
// SIGNAL CORE (M5/H1): Price crosses รวบเส้น + sent > bbMa + deep pullback
// ============================================================================
bool xUp1 = ta.crossover(priceLine, sentiment1) and sentiment1 > bbMa
bool xUp2 = ta.crossover(priceLine, sentiment2) and sentiment2 > bbMa
bool xUp3 = ta.crossover(priceLine, sentiment3) and sentiment3 > bbMa
bool crossUpAboveMid = xUp1 or xUp2 or xUp3

bool xDn1 = ta.crossunder(priceLine, sentiment1) and sentiment1 < bbMa
bool xDn2 = ta.crossunder(priceLine, sentiment2) and sentiment2 < bbMa
bool xDn3 = ta.crossunder(priceLine, sentiment3) and sentiment3 < bbMa
bool crossDnBelowMid = xDn1 or xDn2 or xDn3

float pLineRecentLow  = ta.lowest(priceLine, tdiDipLookback)
float pLineRecentHigh = ta.highest(priceLine, tdiDipLookback)
float sentHi = math.max(sentiment1, math.max(sentiment2, sentiment3))
float sentLo = math.min(sentiment1, math.min(sentiment2, sentiment3))
bool  deepDip  = pLineRecentLow < sentHi
bool  deepRise = pLineRecentHigh > sentLo

// ============================================================================
// M15: Price vs Sentiment (for bar color)
// ============================================================================
bool ybCrossUp = ta.crossover(priceLine, sentimentMain)
bool ybCrossDn = ta.crossunder(priceLine, sentimentMain)

// ============================================================================
// FILTERS
// ============================================================================
// --- Flat EMA (Alignment + ATR-Relative Spread) — EMA ยังไม่กาง ---
bool  alignedUp = ema8 > ema14 and ema14 > ema60
bool  alignedDn = ema8 < ema14 and ema14 < ema60
bool  aligned   = emaBull ? alignedUp : alignedDn
float fanATR    = math.abs(ema8 - ema60) / atrVal
bool  isFlatEma = flatEmaMode != "OFF" and (not aligned or fanATR < flatThresh)

// --- Momentum Bar (สำหรับ Dashboard เท่านั้น) ---
float bodySize = math.abs(close - open)
float avgBody  = ta.sma(bodySize, 20)
bool  isMomBar = bodySize > avgBody * 1.5

// --- Fair Price = pullback swing เคยแตะ EMA8 ใน N แท่งล่าสุด ---
float swingLo = ta.lowest(low,  fairLookback)
float swingHi = ta.highest(high, fairLookback)
bool  isFairPrice = swingLo <= ema8 and swingHi >= ema8

// --- Powerful Mode (close เกิน peak/trough ใน N แท่ง) ---
bool isOverextBuy  = not na(powerRefHi) and close > powerRefHi
bool isOverextSell = not na(powerRefLo) and close < powerRefLo

// --- Time Filter ---
string tzStr       = alertTZ >= 0 ? str.format("UTC+{0}", alertTZ) : str.format("UTC{0}", alertTZ)
int    currentMins = hour(time, tzStr) * 60 + minute(time, tzStr)
int    startMins   = startH * 60 + startMin
int    endMins     = endH * 60 + endMin

bool inAlertTime = true
if specTimeOn
    if startMins < endMins
        inAlertTime := currentMins >= startMins and currentMins <= endMins
    else
        inAlertTime := currentMins >= startMins or currentMins <= endMins

// ============================================================================
// COMBINE FILTERS → SIGNAL
// ============================================================================
bool fairOk       = not fairPriceOn or isFairPrice
// Flat EMA logic:
//   ON - Hide: ถ้า flat → block (flatOk = false) → สัญญาณหาย
//   ON - Show: ถ้า flat → สัญญาณปกติ block, โชว์ minimal signal (ส้ม) แทน
bool flatBlocksRegular = isFlatEma and (flatEmaMode == "ON - Hide" or flatEmaMode == "ON - Show")
bool flatOk            = not flatBlocksRegular
bool flatShowMin       = isFlatEma and flatEmaMode == "ON - Show"
bool powerBuyOk        = not powerfulOn or not isOverextBuy
bool powerSellOk       = not powerfulOn or not isOverextSell

bool isGreenBar = close > open
bool isRedBar   = close < open

bool htfBuyOk  = not htfFilterOn or high > htfEma60
bool htfSellOk = not htfFilterOn or low  < htfEma60

bool coreBuy  = isSignalTF and emaBull     and ema14 > ema60 and htfBuyOk  and crossUpAboveMid and deepDip  and isGreenBar
bool coreSell = isSignalTF and not emaBull and ema14 < ema60 and htfSellOk and crossDnBelowMid and deepRise and isRedBar

bool buySignal  = coreBuy  and fairOk and flatOk and powerBuyOk  and inAlertTime
bool sellSignal = coreSell and fairOk and flatOk and powerSellOk and inAlertTime

bool buyMinSig  = coreBuy  and flatShowMin and fairOk and powerBuyOk  and inAlertTime
bool sellMinSig = coreSell and flatShowMin and fairOk and powerSellOk and inAlertTime

bool buyBlocked  = coreBuy  and fairOk and flatOk and isOverextBuy  and powerfulOn and inAlertTime
bool sellBlocked = coreSell and fairOk and flatOk and isOverextSell and powerfulOn and inAlertTime

// ============================================================================
// PLOT POWERFUL REFERENCE + VALUE ZONE (debug)
// ============================================================================
plot(powerShowRef and powerfulOn ? powerRefHi : na, title="Powerful Ref Hi", color=color.new(#9c27b0, 50), style=plot.style_circles, linewidth=1)
plot(powerShowRef and powerfulOn ? powerRefLo : na, title="Powerful Ref Lo", color=color.new(#9c27b0, 50), style=plot.style_circles, linewidth=1)

plot(fairPriceShow ? ema8 : na, title="Fair Price (EMA8)", color=color.new(#ffb300, 0), linewidth=2)
plot(htfShow ? htfEma60 : na, title="HTF EMA60", color=color.new(#00bcd4, 0), linewidth=2)

// ============================================================================
// PLOT SIGNALS
// ============================================================================
plotshape(buySignal,  title="Buy Signal",  style=shape.labeldown, location=location.abovebar, color=#1b5e20, textcolor=#ffffff, text="Buy",  size=size.small)
plotshape(sellSignal, title="Sell Signal", style=shape.labelup,   location=location.belowbar, color=#b71c1c, textcolor=#ffffff, text="Sell", size=size.small)

plotshape(buyMinSig,  title="Flat Min Buy",  style=shape.labeldown, location=location.abovebar, color=#ff9800, textcolor=#ffffff, text="Buy",  size=size.tiny)
plotshape(sellMinSig, title="Flat Min Sell", style=shape.labelup,   location=location.belowbar, color=#ff9800, textcolor=#ffffff, text="Sell", size=size.tiny)

plotshape(powerShowDot and buyBlocked,  title="Buy Blocked",  style=shape.circle, location=location.abovebar, color=color.new(#9c27b0, 0), size=size.tiny)
plotshape(powerShowDot and sellBlocked, title="Sell Blocked", style=shape.circle, location=location.belowbar, color=color.new(#9c27b0, 0), size=size.tiny)

// ============================================================================
// BAR COLOR — M15 ONLY
// ============================================================================
var int emaState = 0
if ema8x14up
    emaState := 1
if ema8x14dn
    emaState := -1

var int ybState = 0
if ybCrossUp
    ybState := 1
if ybCrossDn
    ybState := -1

bool stateChanged = ema8x14up or ema8x14dn or ybCrossUp or ybCrossDn

color barCol = na
if isM15 and barColorOn and stateChanged
    if emaState == 1 and ybState == 1
        barCol := #4caf50
    else if emaState == -1 and ybState == -1
        barCol := #f44336
    else
        barCol := #ffeb3b

barcolor(barCol, title="Bar Color")

// ============================================================================
// DASHBOARD — M15 ONLY
// ============================================================================
// Precompute history-dependent series at global scope so they update every bar
float dashAtrNorm     = atrVal / close * 100
float dashAtrNormSma  = ta.sma(dashAtrNorm, 50)
int   dashMomBarsAgo  = ta.barssince(isMomBar and (close > open ? emaBull : not emaBull))

if dashOn and isM15 and barstate.islast
    bool chkPattern = dashAtrNorm < dashAtrNormSma
    bool chkMOM     = dashMomBarsAgo <= 10
    bool chkFibo    = (close >= math.min(ema14, ema60) and close <= math.max(ema14, ema60)) or math.abs(close - ema14) < atrVal * 1.5

    tblPos = switch dashLoc
        "Top Left"     => position.top_left
        "Top Right"    => position.top_right
        "Bottom Left"  => position.bottom_left
        =>                position.bottom_right

    tblSz = switch dashSize
        "normal" => size.normal
        "large"  => size.large
        =>          size.small

    var table dash = na
    dash := table.new(tblPos, 3, 7, bgcolor=color.new(#1e1e1e, 10), border_width=1, border_color=color.new(color.gray, 50))

    table.cell(dash, 0, 0, "LOSTXKER Checklist", text_color=color.white, text_size=tblSz, bgcolor=color.new(#333333, 0), text_halign=text.align_left)
    table.merge_cells(dash, 0, 0, 2, 0)

    table.cell(dash, 0, 1, "#",         text_color=color.gray, text_size=tblSz)
    table.cell(dash, 1, 1, "Condition", text_color=color.gray, text_size=tblSz, text_halign=text.align_left)
    table.cell(dash, 2, 1, "Status",    text_color=color.gray, text_size=tblSz)

    table.cell(dash, 0, 2, "1", text_color=color.white, text_size=tblSz)
    table.cell(dash, 1, 2, "BVS", text_color=color.white, text_size=tblSz, text_halign=text.align_left)
    table.cell(dash, 2, 2, "manual", text_color=color.new(color.gray, 0), text_size=tblSz)

    table.cell(dash, 0, 3, "2", text_color=color.white, text_size=tblSz)
    table.cell(dash, 1, 3, "Pattern", text_color=color.white, text_size=tblSz, text_halign=text.align_left)
    table.cell(dash, 2, 3, chkPattern ? "OK" : "X", text_color=chkPattern ? #4caf50 : #f44336, text_size=tblSz)

    table.cell(dash, 0, 4, "3", text_color=color.white, text_size=tblSz)
    table.cell(dash, 1, 4, "MOM", text_color=color.white, text_size=tblSz, text_halign=text.align_left)
    table.cell(dash, 2, 4, chkMOM ? "OK" : "X", text_color=chkMOM ? #4caf50 : #f44336, text_size=tblSz)

    table.cell(dash, 0, 5, "4", text_color=color.white, text_size=tblSz)
    table.cell(dash, 1, 5, "Fair Price", text_color=color.white, text_size=tblSz, text_halign=text.align_left)
    table.cell(dash, 2, 5, isFairPrice ? "OK" : "X", text_color=isFairPrice ? #4caf50 : #f44336, text_size=tblSz)

    table.cell(dash, 0, 6, "5", text_color=color.white, text_size=tblSz)
    table.cell(dash, 1, 6, "Fibo Zone", text_color=color.white, text_size=tblSz, text_halign=text.align_left)
    table.cell(dash, 2, 6, chkFibo ? "OK" : "X", text_color=chkFibo ? #4caf50 : #f44336, text_size=tblSz)

// ============================================================================
// ALERTS — รองรับทั้ง LINE Proxy (JSON schema) และ Discord Webhook
//   LINE Proxy : https://line-webhook-proxy-one.vercel.app/api/trading-alert
//                schema = { type, dir, pair, tf, price, time }
//   Discord    : payload = {"content":"(Confirmed) US30 ⏱️20:55 🟢"}
//                ตั้ง Webhook URL ของ Discord channel ในช่อง Webhook URL ของ TradingView Alert
// ============================================================================
string timeStr = str.format("{0,number,00}:{1,number,00}", hour(time, tzStr), minute(time, tzStr))

bool ncBuy  = buySignal  and not barstate.isconfirmed
bool ncSell = sellSignal and not barstate.isconfirmed
bool cfBuy  = buySignal  and barstate.isconfirmed
bool cfSell = sellSignal and barstate.isconfirmed

makeLineJson(string tpe, string dir) =>
    '{"type":"' + tpe
     + '","dir":"' + dir
     + '","pair":"' + syminfo.ticker
     + '","tf":"' + timeframe.period
     + '","price":"' + str.tostring(close, format.mintick)
     + '","time":"' + timeStr
     + '"}'

makeDiscordJson(string tpe, string dir) =>
    string label = tpe == "CONFIRMED" ? "(Confirmed)" : "(Not confirm)"
    string emoji = dir == "BULL" ? "🟢" : "🔴"
    string content = label + " " + syminfo.ticker + " ⏱️" + timeStr + " " + emoji
    '{"content":"' + content + '"}'

makeAlertJson(string tpe, string dir) =>
    alertTarget == "Discord" ? makeDiscordJson(tpe, dir) : makeLineJson(tpe, dir)

if ncBuy
    alert(makeAlertJson("NOT_CONFIRM", "BULL"), alert.freq_once_per_bar)
if cfBuy
    alert(makeAlertJson("CONFIRMED",   "BULL"), alert.freq_once_per_bar_close)
if ncSell
    alert(makeAlertJson("NOT_CONFIRM", "BEAR"), alert.freq_once_per_bar)
if cfSell
    alert(makeAlertJson("CONFIRMED",   "BEAR"), alert.freq_once_per_bar_close)

// --- LINE Proxy alertconditions (เดิม) ---
alertcondition(cfBuy,           title="CF Buy (LINE)",        message='{"type":"CONFIRMED","dir":"BULL","pair":"{{ticker}}","tf":"{{interval}}","price":"{{close}}"}')
alertcondition(cfSell,          title="CF Sell (LINE)",       message='{"type":"CONFIRMED","dir":"BEAR","pair":"{{ticker}}","tf":"{{interval}}","price":"{{close}}"}')
alertcondition(cfBuy or cfSell, title="All Confirmed (LINE)", message='{"type":"CONFIRMED","dir":"ANY","pair":"{{ticker}}","tf":"{{interval}}","price":"{{close}}"}')

// --- Discord Webhook alertconditions ---
alertcondition(ncBuy,  title="NC Buy (Discord)",  message='{"content":"(Not confirm) {{ticker}} ⏱️{{time}} 🟢"}')
alertcondition(ncSell, title="NC Sell (Discord)", message='{"content":"(Not confirm) {{ticker}} ⏱️{{time}} 🔴"}')
alertcondition(cfBuy,  title="CF Buy (Discord)",  message='{"content":"(Confirmed) {{ticker}} ⏱️{{time}} 🟢"}')
alertcondition(cfSell, title="CF Sell (Discord)", message='{"content":"(Confirmed) {{ticker}} ⏱️{{time}} 🔴"}')
