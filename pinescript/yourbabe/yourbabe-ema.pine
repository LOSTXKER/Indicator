// Yourbabe's EMA
// EMA 6 lines (Current + HTF) + Clouds + HTF Background + Sessions + AOF + Server Close
//@version=6
indicator("Yourbabe's EMA", shorttitle="YB EMA", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ============================================================================
// INPUTS — EMA
// ============================================================================
string GRP_EMA = "EMA"
int    emaLen1  = input.int(8,  "EMA 1", group=GRP_EMA)
int    emaLen2  = input.int(14, "EMA 2", group=GRP_EMA)
int    emaLen3  = input.int(60, "EMA 3", group=GRP_EMA)
color  emaClr1  = input.color(#4caf50, "EMA 1 Color", inline="c1", group=GRP_EMA)
color  emaClr2  = input.color(#e91e63, "",             inline="c1", group=GRP_EMA)
color  emaClr3  = input.color(#ffffff, "",             inline="c1", group=GRP_EMA)
bool   cloudOn  = input.bool(true, "EMA Cloud Fill", group=GRP_EMA)
float  cloudPad = input.float(0.25, "Cloud 14-60 Padding", minval=0.0, maxval=0.45, step=0.05, group=GRP_EMA, tooltip="0 = ติดเส้น, 0.45 = cloud แคบสุด")

// ============================================================================
// INPUTS — HTF
// ============================================================================
string GRP_HTF = "HTF"
bool   htfOn    = input.bool(true, "Show HTF EMA", group=GRP_HTF)
bool   htfBgOn  = input.bool(true, "HTF Background", group=GRP_HTF)
int    htfBgTr  = input.int(94, "BG Transparency", minval=80, maxval=99, group=GRP_HTF)

// ============================================================================
// INPUTS — SESSIONS
// ============================================================================
string GRP_SES = "SESSIONS"
bool   sesOn     = input.bool(true, "Show Sessions", group=GRP_SES)
int    utcOffset = input.int(7, "UTC Offset", minval=-12, maxval=14, group=GRP_SES)
bool   tokyoOn   = input.bool(true,  "Tokyo",   inline="tk", group=GRP_SES)
color  tokyoClr  = input.color(color.new(#1565c0, 92), "", inline="tk", group=GRP_SES)
bool   londonOn  = input.bool(true,  "London",  inline="ld", group=GRP_SES)
color  londonClr = input.color(color.new(#ff8f00, 92), "", inline="ld", group=GRP_SES)
bool   nyOn      = input.bool(true,  "New York", inline="ny", group=GRP_SES)
color  nyClr     = input.color(color.new(#c62828, 92), "", inline="ny", group=GRP_SES)
bool   sesLabel  = input.bool(true, "Session Labels", group=GRP_SES)

// ============================================================================
// INPUTS — AOF
// ============================================================================
string GRP_AOF = "AOF (Area of Flow)"
bool   aofOn    = input.bool(true, "Show AOF", group=GRP_AOF)
int    aofHours = input.int(11, "Range (Hours)", minval=1, group=GRP_AOF)
int    aofShift = input.int(-5, "Shift (Hours)", group=GRP_AOF)
color  aofClr   = input.color(color.new(#7e57c2, 90), "Color", group=GRP_AOF)

// ============================================================================
// INPUTS — SERVER CLOSE
// ============================================================================
string GRP_SC = "SERVER CLOSE"
bool   scOn       = input.bool(true, "Server Close Mark", group=GRP_SC)
bool   scDST      = input.bool(false, "Daylight Saving", group=GRP_SC)
color  scClr      = input.color(color.new(color.gray, 50), "Color", group=GRP_SC)
int    scBarBack  = input.int(500, "Bar Back", minval=1, group=GRP_SC)

// ============================================================================
// HTF AUTO-DETECT
// ============================================================================
htfTF = switch timeframe.period
    "1"   => "5"
    "3"   => "15"
    "5"   => "15"
    "15"  => "60"
    "30"  => "60"
    "60"  => "240"
    "240" => "D"
    =>       "D"

// ============================================================================
// EMA — CURRENT TF
// ============================================================================
ema1 = ta.ema(close, emaLen1)
ema2 = ta.ema(close, emaLen2)
ema3 = ta.ema(close, emaLen3)

color ema14clr = ema1 > ema2 ? #4caf50 : #f44336

float emaDist   = math.abs(ema2 - ema3)
float cloudMarg = emaDist * cloudPad
float ema2inner = ema2 > ema3 ? ema2 - cloudMarg : ema2 + cloudMarg
float ema3inner = ema3 > ema2 ? ema3 - cloudMarg : ema3 + cloudMarg

p1 = plot(ema1, "EMA 8",  color=color.new(color.white, 100), linewidth=2)
p2 = plot(ema2, "EMA 14", color=ema14clr, linewidth=3)
p3 = plot(ema3, "EMA 60", color=emaClr3, linewidth=2)
p2i = plot(ema2inner, "Cloud 14 inner", color=color.new(color.white, 100), linewidth=1, display=display.none)
p3i = plot(ema3inner, "Cloud 60 inner", color=color.new(color.white, 100), linewidth=1, display=display.none)

// ============================================================================
// EMA — HTF (smooth: EMA period x multiplier)
// ============================================================================
htfMult = switch timeframe.period
    "1"   => 5
    "3"   => 5
    "5"   => 3
    "15"  => 4
    "30"  => 2
    "60"  => 4
    "240" => 6
    =>       1

htfEma3 = ta.ema(close, emaLen3 * htfMult)

plot(htfOn ? htfEma3 : na, "HTF EMA 60", color=color.new(#00bcd4, 0), linewidth=3)

// ============================================================================
// EMA CLOUD FILL
// ============================================================================
color cloud12 = ema1 > ema2 ? color.new(#2e7d32, 65) : color.new(#c62828, 65)
color cloud23 = ema2 > ema3 ? color.new(#9c27b0, 80) : color.new(#ff9800, 80)

fill(p1, p2, color=cloudOn ? cloud12 : na, title="Cloud 8-14")
fill(p2i, p3i, color=cloudOn ? cloud23 : na, title="Cloud 14-60")

// ============================================================================
// HTF BACKGROUND (use current TF EMA alignment as proxy)
// ============================================================================
bool emaBull = ema1 > ema2 and ema2 > ema3
bool emaBear = ema1 < ema2 and ema2 < ema3

bgcolor(htfBgOn and emaBull ? color.new(#4caf50, htfBgTr) : htfBgOn and emaBear ? color.new(#9c27b0, htfBgTr) : na, title="HTF Background")

// ============================================================================
// SESSIONS
// ============================================================================
tokyoSes()  =>
    utcStart = 5 - utcOffset
    utcEnd   = 14 - utcOffset
    sH = (utcStart + 24) % 24
    eH = (utcEnd + 24) % 24
    str.format("{0,number,00}00-{1,number,00}00", sH, eH)

londonSes() =>
    utcStart = 14 - utcOffset
    utcEnd   = 0 - utcOffset
    sH = (utcStart + 24) % 24
    eH = (utcEnd + 24) % 24
    str.format("{0,number,00}00-{1,number,00}00", sH, eH)

nySes()     =>
    utcStart = 19 - utcOffset
    utcEnd   = 5 - utcOffset
    sH = (utcStart + 24) % 24
    eH = (utcEnd + 24) % 24
    str.format("{0,number,00}00-{1,number,00}00", sH, eH)

drawSession(string sesStr, color clr, string label_text, bool showLabel) =>
    inSes = not na(time(timeframe.period, sesStr, "UTC"))
    var box  sesBox   = na
    var bool wasInSes = false
    if inSes and not wasInSes
        sesBox := box.new(bar_index, high, bar_index, low, bgcolor=clr, border_color=color.new(clr, 80), border_width=1)
        if showLabel
            label.new(bar_index, high, label_text, color=color.new(color.black, 100), textcolor=color.new(color.white, 30), style=label.style_label_down, size=size.tiny)
    if inSes
        box.set_right(sesBox, bar_index)
        box.set_top(sesBox, math.max(box.get_top(sesBox), high))
        box.set_bottom(sesBox, math.min(box.get_bottom(sesBox), low))
    wasInSes := inSes

if sesOn and tokyoOn
    drawSession(tokyoSes(), tokyoClr, "Tokyo", sesLabel)
if sesOn and londonOn
    drawSession(londonSes(), londonClr, "London", sesLabel)
if sesOn and nyOn
    drawSession(nySes(), nyClr, "New York", sesLabel)

// ============================================================================
// AOF (Area of Flow)
// ============================================================================
if aofOn
    int aofBars   = math.max(int(aofHours * 60 / timeframe.multiplier), 1)
    int shiftBars = int(aofShift * 60 / timeframe.multiplier)

    var box aofBox = na
    var int lastDay = -1
    currentDay = dayofweek(time)

    if currentDay != lastDay
        aofHi = ta.highest(high, aofBars)
        aofLo = ta.lowest(low,   aofBars)
        aofBox := box.new(bar_index - aofBars + shiftBars, aofHi, bar_index + shiftBars, aofLo, bgcolor=aofClr, border_color=color.new(aofClr, 70), border_width=1)
        lastDay := currentDay

// ============================================================================
// SERVER CLOSE MARK
// ============================================================================
if scOn
    closeHour = scDST ? 16 : 17
    tzStr     = utcOffset >= 0 ? str.format("UTC+{0}", utcOffset) : str.format("UTC{0}", utcOffset)
    h         = hour(time, tzStr)
    m         = minute(time, tzStr)

    if h == closeHour and m == 0 and bar_index > (last_bar_index - scBarBack)
        line.new(bar_index, high * 1.001, bar_index, low * 0.999, color=scClr, style=line.style_dashed, width=1, extend=extend.both)
