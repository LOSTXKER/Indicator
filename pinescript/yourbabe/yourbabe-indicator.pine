// Yourbabe's Indicator
// TDI-based oscillator: Price Line + Sentiment lines (ruobsen) + Middle Band + Mountain fills
//@version=6
indicator("YOUR BABEs Indicator", shorttitle="YB Indicator", overlay=false, max_bars_back=500)

// ============================================================================
// INPUTS — TDI CORE
// ============================================================================
string GRP_TDI = "TDI SETTINGS"
int    rsiPeriod = input.int(13,     "RSI Period",    minval=1, group=GRP_TDI)
int    bandLen   = input.int(31,     "Band Length",   minval=1, group=GRP_TDI)
float  bandMult  = input.float(1.6185, "Band Multiplier", step=0.001, group=GRP_TDI)

// ============================================================================
// INPUTS — LINES
// ============================================================================
string GRP_LINE = "LINE SETTINGS"
int    pricePeriod = input.int(1,  "Price Line Period",     minval=1, group=GRP_LINE, tooltip="SMA of RSI — period 1 = raw RSI")
int    sentPeriod  = input.int(8,  "Sentiment Period (M15)", minval=1, group=GRP_LINE, tooltip="M15 Sentiment line")
int    sent1Period = input.int(6,  "รวบเส้น 1 Period",       minval=1, group=GRP_LINE)
int    sent2Period = input.int(8,  "รวบเส้น 2 Period",       minval=1, group=GRP_LINE)
int    sent3Period = input.int(9,  "รวบเส้น 3 Period",       minval=1, group=GRP_LINE)

// ============================================================================
// INPUTS — COLORS
// ============================================================================
string GRP_CLR = "COLORS"
color  priceUpClr   = input.color(#4caf50, "Price Line Up",   inline="pc", group=GRP_CLR)
color  priceDnClr   = input.color(#f44336, "Price Line Down",  inline="pc", group=GRP_CLR)
color  midBullClr   = input.color(#9c27b0, "Middle Band Bull",   inline="mb", group=GRP_CLR)
color  midBearClr   = input.color(#ff9800, "Middle Band Bear",   inline="mb", group=GRP_CLR)
color  midNeutClr   = input.color(#ffeb3b, "Middle Band Neutral", inline="mb", group=GRP_CLR)
color  mtnBullClr   = input.color(#00897b, "Mountain Bull",    inline="mt", group=GRP_CLR)
color  mtnBearClr   = input.color(#8d6e63, "Mountain Bear",    inline="mt", group=GRP_CLR)

// ============================================================================
// INPUTS — DISPLAY
// ============================================================================
string GRP_DISP = "DISPLAY"
bool   mtnOn     = input.bool(true,  "Mountain Fills", group=GRP_DISP)
bool   bandsOn   = input.bool(false, "Show BB Bands", group=GRP_DISP)

// ============================================================================
// TDI CALCULATION
// ============================================================================
rsiVal     = ta.rsi(close, rsiPeriod)
bbMa       = ta.sma(rsiVal, bandLen)
bbStd      = ta.stdev(rsiVal, bandLen)
upperBand  = bbMa + bandMult * bbStd
lowerBand  = bbMa - bandMult * bbStd

// ============================================================================
// TF DETECTION
// ============================================================================
bool isM5  = timeframe.period == "5"
bool isM15 = timeframe.period == "15"

// ============================================================================
// LINES
// ============================================================================
priceLine     = ta.sma(rsiVal, pricePeriod)
sentimentMain = ta.sma(rsiVal, sentPeriod)
sentiment1    = ta.sma(rsiVal, sent1Period)
sentiment2    = ta.sma(rsiVal, sent2Period)
sentiment3    = ta.sma(rsiVal, sent3Period)

// ============================================================================
// PRICE LINE COLOR
// ============================================================================
// M5:  changes on crossing ANY รวบเส้น
// M15: changes on crossing Sentiment หลัก
bool crossUpM5 = (priceLine > sentiment1 and priceLine[1] <= sentiment1[1]) or
                  (priceLine > sentiment2 and priceLine[1] <= sentiment2[1]) or
                  (priceLine > sentiment3 and priceLine[1] <= sentiment3[1])

bool crossDnM5 = (priceLine < sentiment1 and priceLine[1] >= sentiment1[1]) or
                  (priceLine < sentiment2 and priceLine[1] >= sentiment2[1]) or
                  (priceLine < sentiment3 and priceLine[1] >= sentiment3[1])

bool crossUp = crossUpM5
bool crossDn = crossDnM5

var bool priceIsUpM5 = true
if crossUp
    priceIsUpM5 := true
if crossDn
    priceIsUpM5 := false

color priceClr = isM15 ? (priceLine > sentimentMain ? priceUpClr : priceDnClr) : (priceIsUpM5 ? priceUpClr : priceDnClr)

// ============================================================================
// SENTIMENT GROUP — min / max for mountain fills (M5 only)
// ============================================================================
float sentHi = math.max(sentiment1, math.max(sentiment2, sentiment3))
float sentLo = math.min(sentiment1, math.min(sentiment2, sentiment3))

// ============================================================================
// รวบเส้น COLORS — all 3 cross Middle Band (M5 only)
// ============================================================================
bool allAboveMid = sentiment1 > bbMa and sentiment2 > bbMa and sentiment3 > bbMa
bool allBelowMid = sentiment1 < bbMa and sentiment2 < bbMa and sentiment3 < bbMa

color ruobsenClr = allAboveMid ? color.new(mtnBullClr, 20) : allBelowMid ? color.new(mtnBearClr, 20) : color.new(mtnBearClr, 50)

// ============================================================================
// MIDDLE BAND COLOR
// ============================================================================
// M5:  3 สี (ม่วง / ส้ม / เหลือง) ตาม รวบเส้น vs Middle Band
// M15: 2 สี (ม่วง / ส้ม) ตาม Price vs Middle Band
color midClr = allAboveMid ? midBullClr : allBelowMid ? midBearClr : midNeutClr

// ============================================================================
// PLOTS
// ============================================================================
pPlot    = plot(priceLine,     "Price Line",   color=priceClr, linewidth=2)
smPlot   = plot(isM15 ? sentimentMain : na, "Sentiment", color=color.new(#ff9800, 0), linewidth=1)
s1Plot   = plot(isM15 ? na : sentiment1,    "รวบเส้น 1",  color=ruobsenClr, linewidth=1)
s2Plot   = plot(isM15 ? na : sentiment2,    "รวบเส้น 2",  color=ruobsenClr, linewidth=1)
s3Plot   = plot(isM15 ? na : sentiment3,    "รวบเส้น 3",  color=ruobsenClr, linewidth=1)
midPlot  = plot(isM15 ? na : bbMa, "Middle Band", color=midClr, linewidth=2)
hiPlot   = plot(isM15 ? na : sentHi,  "Sent High", color=color.new(color.white, 100), linewidth=1, display=display.none)
loPlot   = plot(isM15 ? na : sentLo,  "Sent Low",  color=color.new(color.white, 100), linewidth=1, display=display.none)

plot(bandsOn ? upperBand : na, "Upper Band", color=color.new(#2196f3, 70), linewidth=1)
plot(bandsOn ? lowerBand : na, "Lower Band", color=color.new(#2196f3, 70), linewidth=1)

// ============================================================================
// MOUNTAIN FILLS — only between the 3 รวบเส้น lines
// ============================================================================
color coreFill = mtnOn and not isM15 ? (allAboveMid ? color.new(mtnBullClr, 50) : allBelowMid ? color.new(mtnBearClr, 50) : color.new(mtnBearClr, 70)) : na
fill(hiPlot, loPlot, color=coreFill, title="Mountain Core")

// ============================================================================
// HLINES
// ============================================================================
hline(80, "Extremely Overbought", color=color.new(color.gray, 60))
hline(70, "Overbought",           color=color.new(color.gray, 60))
hline(50, "Midline",              color=color.new(color.gray, 40), linestyle=hline.style_solid)
hline(30, "Oversold",             color=color.new(color.gray, 60))
hline(20, "Extremely Oversold",   color=color.new(color.gray, 60))
