// This Pine Script™ is subject to the terms of the Mozilla Public License 2.0
// https://mozilla.org/MPL/2.0/
// © OVS/OVB Base Indicator

//@version=6
indicator("OVS/OVB Base", overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 200, max_bars_back = 5000)

// ─────────────────────────────────────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────────────────────────────────────

grpCore    = "⚙️ Stochastic"
i_kPeriod  = input.int(9,   "K Period",  minval = 1,  group = grpCore)
i_slowing  = input.int(3,   "Slowing",   minval = 1,  group = grpCore)
i_ovsLevel = input.int(20,  "OVS Level", minval = 1,  maxval = 49, group = grpCore)
i_ovbLevel = input.int(80,  "OVB Level", minval = 51, maxval = 99, group = grpCore)

grpRsiCut    = "📍 RSI Cut"
i_rsiCutEnabled = input.bool(true,  "เปิดใช้ RSI Cut",  group = grpRsiCut)
i_rsiPeriod     = input.int(14,     "RSI Period",       minval = 1, group = grpRsiCut)
i_rsiOvsLevel   = input.int(30,     "RSI OVS Level",    minval = 1,  maxval = 49, group = grpRsiCut)
i_rsiOvbLevel   = input.int(70,     "RSI OVB Level",    minval = 51, maxval = 99, group = grpRsiCut)

grpEMA     = "📍 EMA"
i_emaFast  = input.int(14, "Fast EMA",  minval = 1, group = grpEMA)
i_emaSlow  = input.int(60, "Slow EMA",  minval = 1, group = grpEMA)
i_showEMA  = input.bool(true, "แสดงเส้น EMA", group = grpEMA)
i_showEMAbg = input.bool(true, "แสดงพื้นหลัง EMA Cross", group = grpEMA)

grpPB      = "🎯 Pullback Strategy"
i_adxLen        = input.int(14, "ADX Length", minval = 5, maxval = 50, group = grpPB)
i_adxThresh     = input.int(20, "ADX Sideway Threshold", minval = 10, maxval = 40, group = grpPB,
     tooltip = "ADX ต่ำกว่านี้ = Sideway ไม่มีเทรน (แนะนำ 20-25)")
i_bbLen         = input.int(20, "BB Length", minval = 5, maxval = 50, group = grpPB)
i_bbMult        = input.float(2.0, "BB Multiplier", minval = 1.0, maxval = 4.0, step = 0.1, group = grpPB)
i_pbBars        = input.int(1, "PB Candles", minval = 1, maxval = 5, group = grpPB,
     tooltip = "จำนวนแท่งย่อติดต่อกันก่อนกลับตัว (1 = จับ PB ตื้นได้)")
i_pbSwingLen    = input.int(6, "Swing Lookback", minval = 3, maxval = 20, group = grpPB,
     tooltip = "ช่วงหา Swing High/Low")
i_pbH1          = input.bool(true, "H1 Pullback", group = grpPB)
i_showPbDots    = input.bool(true, "แสดงจุด PB (Phase 2)", group = grpPB,
     tooltip = "จุด x บอกว่ามีแท่งกลับตัวในโซนสำคัญแล้ว")
i_showPbZone    = input.bool(true, "แสดง PB Fib Zone", group = grpPB,
     tooltip = "เส้น Fib + เปลี่ยนสีแท่งเมื่อราคาอยู่ในโซน pullback")
i_showSweep     = input.bool(true, "แสดง Liquidity Sweep", group = grpPB,
     tooltip = "จุดที่ราคา wick ทะลุ swing แล้วกลับตัว (stop hunt)")
i_showOB        = input.bool(true, "แสดง Order Block", group = grpPB,
     tooltip = "แท่งสุดท้ายก่อน impulse move — จุดที่สถาบันวาง order")
i_showH1BB      = input.bool(false, "แสดง H1 Bollinger Bands", group = grpPB)

grpFVG = "📦 FVG (Fair Value Gap)"
i_showFVG      = input.bool(true, "แสดง H1 FVG", group = grpFVG)
i_fvgMaxBoxes  = input.int(10, "จำนวน FVG สูงสุด", minval = 3, maxval = 50, group = grpFVG)

grpSess = "⏰ Session / Kill Zone (ICT)"
i_sessAsian    = input.bool(true, "Asian Kill Zone", group = grpSess,
     tooltip = "19:00–22:00 NY time — range formation")
i_sessLondon   = input.bool(true, "London Kill Zone", group = grpSess,
     tooltip = "02:00–05:00 NY time — daily directional bias")
i_sessNY       = input.bool(true, "New York Kill Zone", group = grpSess,
     tooltip = "07:00–10:00 NY time — high volatility")
i_sessLdnClose = input.bool(true, "London Close Kill Zone", group = grpSess,
     tooltip = "10:00–12:00 NY time — reversal/continuation")
i_showSessBg   = input.bool(true, "แสดงพื้นหลัง Session", group = grpSess)

grpLevels = "📏 Key Levels"
i_showPDHL = input.bool(true, "แสดง Previous Day High/Low", group = grpLevels)

grpMom = "📈 Momentum Candle"
i_momAvgLen    = input.int(15, "Avg Body Period", minval = 2, group = grpMom)
i_momSuper     = input.float(1.5, "Super Multiplier", minval = 1.0, step = 0.1, group = grpMom)
i_showMomBar   = input.bool(true, "แสดงสีแท่ง M15 Momentum", group = grpMom)

grpDisplay = "📊 แสดงผล"
i_showMarkers = input.bool(true,  "แสดงจุด OVS/OVB",      group = grpDisplay)
i_maxMarkers  = input.int(30, "จำนวนจุดสูงสุด (คู่)",    minval = 5, maxval = 100, group = grpDisplay)
i_showTrend   = input.bool(true, "แสดงป้ายเทรน (UP/DN)",  group = grpDisplay)
i_showZones   = input.bool(false, "แสดงพื้นหลังโซน OVS/OVB", group = grpDisplay)
i_showPattern = input.bool(false, "แสดงเส้น Flag Pattern", group = grpDisplay)
i_pivotLen    = input.int(2, "Pivot Length (Flag)",       minval = 1, maxval = 5, group = grpDisplay)

// ─────────────────────────────────────────────────────────────────────────────
// Constants
// ─────────────────────────────────────────────────────────────────────────────

var int SM_WAIT_OVS = 0
var int SM_WAIT_OVB = 1

// ─────────────────────────────────────────────────────────────────────────────
// Stochastic + RSI (chart TF)
// ─────────────────────────────────────────────────────────────────────────────

kRaw = ta.stoch(close, high, low, i_kPeriod)
kVal = ta.sma(kRaw, i_slowing)

inOvs = kVal < i_ovsLevel
inOvb = kVal > i_ovbLevel

rsiRaw = ta.rsi(close, i_rsiPeriod)
rsiInOvs = rsiRaw < i_rsiOvsLevel
rsiInOvb = rsiRaw > i_rsiOvbLevel

// ─────────────────────────────────────────────────────────────────────────────
// TF Helpers
// ─────────────────────────────────────────────────────────────────────────────

isM15 = timeframe.period == "15"

// ─────────────────────────────────────────────────────────────────────────────
// Main SM State Variables (chart TF)
// ─────────────────────────────────────────────────────────────────────────────

var int   smState = SM_WAIT_OVS
var float ovsLow  = na
var int   ovsBar  = na
var float ovbHigh = na
var int   ovbBar  = na

var label curOvsLbl = na
var label curOvbLbl = na
var array<label> allMarkers = array.new<label>()

var float confirmedOvbHigh    = na
var int   confirmedOvbBar    = na
var float prevConfirmedOvsLow = na
var int   prevConfirmedOvsBar = na
var int   trend        = 0
var float prevOvbHigh  = na
var array<label> trendLabels = array.new<label>()

var float patPivHi    = na
var int   patPivHiBar = na
var float patPivLo    = na
var int   patPivLoBar = na
var array<line> patLines = array.new<line>()

// ─────────────────────────────────────────────────────────────────────────────
// RSI Mountain Cut State Machine
// ─────────────────────────────────────────────────────────────────────────────

var int  RSI_WAIT_FIRST_OVS  = 0
var int  RSI_WAIT_OVB        = 1
var int  RSI_WAIT_SECOND_OVS = 2

var int   rsiCutState = RSI_WAIT_FIRST_OVS
var bool  rsiCutBar   = false

if i_rsiCutEnabled
    rsiCutBar := false
    if rsiCutState == RSI_WAIT_FIRST_OVS and rsiInOvs
        rsiCutState := RSI_WAIT_OVB
    else if rsiCutState == RSI_WAIT_OVB and rsiInOvb
        rsiCutState := RSI_WAIT_SECOND_OVS
    else if rsiCutState == RSI_WAIT_SECOND_OVS and rsiInOvs
        rsiCutBar  := true
        rsiCutState := RSI_WAIT_FIRST_OVS

bgcolor(i_rsiCutEnabled and rsiCutBar ? color.new(color.purple, 70) : na, title = "RSI CUT")

// ─────────────────────────────────────────────────────────────────────────────
// Pivot Detection
// ─────────────────────────────────────────────────────────────────────────────

pivHi = ta.pivothigh(high, i_pivotLen, i_pivotLen)
pivLo = ta.pivotlow(low, i_pivotLen, i_pivotLen)

// ─────────────────────────────────────────────────────────────────────────────
// Main State Machine (chart TF)
// ─────────────────────────────────────────────────────────────────────────────

switch smState
    SM_WAIT_OVS =>
        if not na(pivHi) and na(patPivHi)
            patPivHi    := pivHi
            patPivHiBar := bar_index - i_pivotLen
        if not na(pivLo) and na(patPivLo)
            patPivLo    := pivLo
            patPivLoBar := bar_index - i_pivotLen

        if na(ovsLow) or low < ovsLow
            ovsLow  := low
            ovsBar  := bar_index
            ovbHigh := high
            ovbBar  := bar_index
            if i_showMarkers
                if na(curOvsLbl)
                    curOvsLbl := label.new(bar_index, low, "⏳ S",
                         style = label.style_label_up, color = color.new(color.aqua, 30),
                         textcolor = color.white, size = size.small)
                else
                    label.set_x(curOvsLbl, bar_index)
                    label.set_y(curOvsLbl, low)
        else
            if na(ovbHigh) or high > ovbHigh
                ovbHigh := high
                ovbBar  := bar_index

        if inOvb and not na(ovsLow)
            savedOvsLow = ovsLow
            savedOvsBar = ovsBar

            if not na(curOvsLbl)
                label.set_text(curOvsLbl, "S")
                label.set_style(curOvsLbl, label.style_diamond)
                label.set_color(curOvsLbl, color.aqua)
                label.set_textcolor(curOvsLbl, color.aqua)
                label.set_size(curOvsLbl, size.tiny)
                array.push(allMarkers, curOvsLbl)
                curOvsLbl := na

            if not na(prevConfirmedOvsLow)
                isHL = savedOvsLow > prevConfirmedOvsLow
                isLL = savedOvsLow < prevConfirmedOvsLow
                if trend == 0 and isHL
                    trend := 2
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "⚠HL",
                             style = label.style_label_up, color = color.new(color.yellow, 10),
                             textcolor = color.black, size = size.small))
                else if trend == 0 and isLL
                    trend := -1
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "DN",
                             style = label.style_label_up, color = color.new(color.red, 10),
                             textcolor = color.white, size = size.normal))
                else if trend == -1 and isHL
                    trend := 2
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "⚠HL",
                             style = label.style_label_up, color = color.new(color.yellow, 10),
                             textcolor = color.black, size = size.small))
                else if trend == 1 and isLL
                    trend := -2
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "⚠LL",
                             style = label.style_label_up, color = color.new(color.yellow, 10),
                             textcolor = color.black, size = size.small))
                else if trend == -2 and isLL
                    trend := -1
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "DN",
                             style = label.style_label_up, color = color.new(color.red, 10),
                             textcolor = color.white, size = size.normal))
                else if trend == -2 and isHL
                    trend := 1
                    if i_showTrend
                        array.push(trendLabels, label.new(savedOvsBar, savedOvsLow, "UP",
                             style = label.style_label_up, color = color.new(color.green, 10),
                             textcolor = color.white, size = size.normal))

            prevConfirmedOvsLow := savedOvsLow
            prevConfirmedOvsBar := savedOvsBar

            if i_showPattern and not na(confirmedOvbHigh) and not na(confirmedOvbBar)
                if not na(patPivHi) and not na(patPivHiBar)
                    upperLine = line.new(confirmedOvbBar, confirmedOvbHigh, patPivHiBar, patPivHi,
                         color = color.new(color.white, 20), width = 1, style = line.style_solid, extend = extend.right)
                    array.push(patLines, upperLine)
                if not na(patPivLo) and not na(patPivLoBar)
                    lowerLine = line.new(patPivLoBar, patPivLo, savedOvsBar, savedOvsLow,
                         color = color.new(color.white, 20), width = 1, style = line.style_solid, extend = extend.right)
                    array.push(patLines, lowerLine)
                while array.size(patLines) > 10
                    line.delete(array.get(patLines, 0))
                    array.remove(patLines, 0)

            patPivHi    := na
            patPivHiBar := na
            patPivLo    := na
            patPivLoBar := na

            smState := SM_WAIT_OVB
            ovsLow  := na
            ovsBar  := na
            if i_showMarkers
                curOvbLbl := label.new(ovbBar, ovbHigh, "⏳ B",
                     style = label.style_label_down, color = color.new(color.orange, 30),
                     textcolor = color.white, size = size.small)

    SM_WAIT_OVB =>
        if na(ovbHigh) or high > ovbHigh
            ovbHigh := high
            ovbBar  := bar_index
            ovsLow  := low
            ovsBar  := bar_index
            if i_showMarkers
                if na(curOvbLbl)
                    curOvbLbl := label.new(bar_index, high, "⏳ B",
                         style = label.style_label_down, color = color.new(color.orange, 30),
                         textcolor = color.white, size = size.small)
                else
                    label.set_x(curOvbLbl, bar_index)
                    label.set_y(curOvbLbl, high)
        else
            if na(ovsLow) or low < ovsLow
                ovsLow := low
                ovsBar := bar_index

        if inOvs
            finalOvbHigh = ovbHigh
            finalOvbBar  = ovbBar

            if not na(prevOvbHigh)
                isHH = finalOvbHigh > prevOvbHigh
                isLH = finalOvbHigh < prevOvbHigh
                if trend == 1 and isLH
                    trend := -2
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "⚠LH",
                             style = label.style_label_down, color = color.new(color.yellow, 10),
                             textcolor = color.black, size = size.small))
                else if trend == -1 and isHH
                    trend := 2
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "⚠HH",
                             style = label.style_label_down, color = color.new(color.yellow, 10),
                             textcolor = color.black, size = size.small))
                else if trend == 2 and isHH
                    trend := 1
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "UP",
                             style = label.style_label_down, color = color.new(color.green, 10),
                             textcolor = color.white, size = size.normal))
                else if trend == 2 and isLH
                    trend := -1
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "DN",
                             style = label.style_label_down, color = color.new(color.red, 10),
                             textcolor = color.white, size = size.normal))
                else if trend == -2 and isLH
                    trend := -1
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "DN",
                             style = label.style_label_down, color = color.new(color.red, 10),
                             textcolor = color.white, size = size.normal))
                else if trend == -2 and isHH
                    trend := 1
                    if i_showTrend
                        array.push(trendLabels, label.new(finalOvbBar, finalOvbHigh, "UP",
                             style = label.style_label_down, color = color.new(color.green, 10),
                             textcolor = color.white, size = size.normal))

            prevOvbHigh      := finalOvbHigh
            confirmedOvbHigh := finalOvbHigh
            confirmedOvbBar  := finalOvbBar

            if not na(curOvbLbl)
                label.set_text(curOvbLbl, "B")
                label.set_style(curOvbLbl, label.style_diamond)
                label.set_color(curOvbLbl, color.orange)
                label.set_textcolor(curOvbLbl, color.orange)
                label.set_size(curOvbLbl, size.tiny)
                array.push(allMarkers, curOvbLbl)
                curOvbLbl := na

            patPivHi    := na
            patPivHiBar := na
            patPivLo    := na
            patPivLoBar := na

            smState := SM_WAIT_OVS
            ovbHigh := na
            ovbBar  := na
            if i_showMarkers
                curOvsLbl := label.new(ovsBar, ovsLow, "⏳ S",
                     style = label.style_label_up, color = color.new(color.aqua, 30),
                     textcolor = color.white, size = size.small)

// ─────────────────────────────────────────────────────────────────────────────
// Cleanup old markers
// ─────────────────────────────────────────────────────────────────────────────

while array.size(allMarkers) > i_maxMarkers * 2
    label.delete(array.get(allMarkers, 0))
    array.remove(allMarkers, 0)

while array.size(trendLabels) > 20
    label.delete(array.get(trendLabels, 0))
    array.remove(trendLabels, 0)

// ─────────────────────────────────────────────────────────────────────────────
// Zone Visualization
// ─────────────────────────────────────────────────────────────────────────────

bgcolor(i_showZones and inOvs ? color.new(color.blue, 88) : na, title = "OVS Zone")
bgcolor(i_showZones and inOvb ? color.new(color.red, 88) : na,  title = "OVB Zone")

// ─────────────────────────────────────────────────────────────────────────────
// EMA + Cross Background
// ─────────────────────────────────────────────────────────────────────────────

emaFast = ta.ema(close, i_emaFast)
emaSlow = ta.ema(close, i_emaSlow)

pFast = plot(i_showEMA ? emaFast : na, "EMA Fast", color.new(color.yellow, 0), 2)
pSlow = plot(i_showEMA ? emaSlow : na, "EMA Slow", color.new(#FF9800, 0), 2)

cloudCol = emaFast > emaSlow ? color.new(color.green, 85) : color.new(color.red, 85)
fill(pFast, pSlow, i_showEMAbg ? cloudCol : na, title = "EMA Cloud")

// ─────────────────────────────────────────────────────────────────────────────
// Momentum Candle — Body Range vs Average
// ─────────────────────────────────────────────────────────────────────────────

bodyRange = math.abs(close - open)
avgBody   = ta.sma(bodyRange, i_momAvgLen)

// ─────────────────────────────────────────────────────────────────────────────
// Multi-TF Data Fetching
// ─────────────────────────────────────────────────────────────────────────────

h1PivHi   = ta.pivothigh(high, i_pbSwingLen, i_pbSwingLen)
h1PivLo   = ta.pivotlow(low, i_pbSwingLen, i_pbSwingLen)
prevC1 = close[1]
prevC2 = close[2]
prevC3 = close[3]
_prevH2 = high[2]
_prevL2 = low[2]
_prevO2 = open[2]
_prevBody1 = math.abs(close[1] - open[1])
_h1AvgBody = ta.sma(math.abs(close - open), 14)
_atrVal = ta.atr(14)

[_, _, _adxVal] = ta.dmi(i_adxLen, i_adxLen)
[_bbMid, _bbUp, _bbLo] = ta.bb(close, i_bbLen, i_bbMult)

[h4EmaF, h4EmaS, h4Adx] = request.security(syminfo.tickerid, "240",
     [emaFast, emaSlow, _adxVal])

[pdH, pdL] = request.security(syminfo.tickerid, "D", [high[1], low[1]])

[h1C, h1H, h1L, h1EmaF, h1EmaS, h1T, h1PivH, h1PivL, h1PrevC1, h1PrevC2, h1PrevC3, h1PrevH2, h1PrevL2, h1Atr, h1Adx, h1BbUp, h1BbLo, h1BbMid, h1PrevO2, h1PrevBody1, h1AvgBody] = request.security(syminfo.tickerid, "60",
     [close, high, low, emaFast, emaSlow, time, h1PivHi, h1PivLo, prevC1, prevC2, prevC3, _prevH2, _prevL2, _atrVal, _adxVal, _bbUp, _bbLo, _bbMid, _prevO2, _prevBody1, _h1AvgBody])

[m15O, m15C, m15Body, m15AvgB] = request.security(syminfo.tickerid, "15",
     [open, close, bodyRange, avgBody])

// --- H1 Bar change detection ---
var int prevH1T = na
h1BarNew = not na(h1T) and (na(prevH1T) or h1T != prevH1T)
if not na(h1T)
    prevH1T := h1T

// --- H1 Real Swing tracking (pivot-based, impulse leg pairing) ---
var float h1LastSwHi    = na
var float h1LastSwLo    = na
var float h1ImpHi       = na
var float h1ImpLo       = na
var int   h1LastSwDir   = 0
h1SwMinRange = not na(h1Atr) ? h1Atr * 1.0 : 0.0
if h1BarNew and not na(h1PivH)
    _swRange = not na(h1LastSwLo) ? h1PivH - h1LastSwLo : h1SwMinRange + 1
    if _swRange >= h1SwMinRange
        h1LastSwHi := h1PivH
        if h1LastSwDir == -1 or na(h1ImpLo)
            h1ImpLo := h1LastSwLo
        h1ImpHi     := h1PivH
        h1LastSwDir := 1
        if i_showPbDots and timeframe.period == "60"
            label.new(bar_index - i_pbSwingLen, h1PivH, "",
                 style = label.style_circle, color = color.new(color.white, 60),
                 size = size.auto, yloc = yloc.abovebar)
if h1BarNew and not na(h1PivL)
    _swRange = not na(h1LastSwHi) ? h1LastSwHi - h1PivL : h1SwMinRange + 1
    if _swRange >= h1SwMinRange
        h1LastSwLo := h1PivL
        if h1LastSwDir == 1 or na(h1ImpHi)
            h1ImpHi := h1LastSwHi
        h1ImpLo     := h1PivL
        h1LastSwDir := -1
        if i_showPbDots and timeframe.period == "60"
            label.new(bar_index - i_pbSwingLen, h1PivL, "",
                 style = label.style_circle, color = color.new(color.white, 60),
                 size = size.auto, yloc = yloc.belowbar)

// ─────────────────────────────────────────────────────────────────────────────
// H1 Liquidity Sweep (Stop Hunt / Swing Failure Pattern)
// ─────────────────────────────────────────────────────────────────────────────

h1SweepBull = h1BarNew and not na(h1L) and not na(h1C) and not na(h1LastSwLo)
     and h1L < h1LastSwLo and h1C > h1LastSwLo
h1SweepBear = h1BarNew and not na(h1H) and not na(h1C) and not na(h1LastSwHi)
     and h1H > h1LastSwHi and h1C < h1LastSwHi

var int h1LastSweepBar  = na
var int h1LastSweepDir  = 0
if h1SweepBull
    h1LastSweepBar := bar_index
    h1LastSweepDir := 1
if h1SweepBear
    h1LastSweepBar := bar_index
    h1LastSweepDir := -1

plotshape(i_showSweep and timeframe.period == "60" and h1SweepBull, style = shape.diamond,
     size = size.tiny, color = color.new(#00BCD4, 0), location = location.belowbar, title = "Sweep Bull")
plotshape(i_showSweep and timeframe.period == "60" and h1SweepBear, style = shape.diamond,
     size = size.tiny, color = color.new(#E040FB, 0), location = location.abovebar, title = "Sweep Bear")

// ─────────────────────────────────────────────────────────────────────────────
// H4 Trend Detection (top-level bias)
// ─────────────────────────────────────────────────────────────────────────────

h4AdxOk = not na(h4Adx) and h4Adx >= i_adxThresh
h4Trend = h4AdxOk ? (h4EmaF > h4EmaS ? 1 : -1) : 0

// ─────────────────────────────────────────────────────────────────────────────
// H1 Trend Detection (ADX + EMA direction)
// ─────────────────────────────────────────────────────────────────────────────

h1AdxOk = not na(h1Adx) and h1Adx >= i_adxThresh
h1Trend = h1AdxOk ? (h1EmaF > h1EmaS ? 1 : -1) : 0

// ─────────────────────────────────────────────────────────────────────────────
// Session / Kill Zone Detection
// ─────────────────────────────────────────────────────────────────────────────

_hrNY = hour(time, "America/New_York")
_asianActive   = i_sessAsian    and _hrNY >= 19 and _hrNY < 22
_londonActive  = i_sessLondon   and _hrNY >= 2  and _hrNY < 5
_nyActive      = i_sessNY       and _hrNY >= 7  and _hrNY < 10
_ldnCloseActive = i_sessLdnClose and _hrNY >= 10 and _hrNY < 12

bgcolor(i_showSessBg and _asianActive    ? color.new(#9C27B0, 92) : na, title = "Asian KZ")
bgcolor(i_showSessBg and _londonActive   ? color.new(#2196F3, 92) : na, title = "London KZ")
bgcolor(i_showSessBg and _nyActive       ? color.new(#FF9800, 92) : na, title = "New York KZ")
bgcolor(i_showSessBg and _ldnCloseActive ? color.new(#4CAF50, 92) : na, title = "London Close KZ")

// ── H1 Bollinger Bands ──
bbUpPlot  = i_showH1BB ? h1BbUp  : na
bbLoPlot  = i_showH1BB ? h1BbLo  : na
bbMidPlot = i_showH1BB ? h1BbMid : na

pBBUp  = plot(bbUpPlot,  "H1 BB Upper", color = color.new(color.orange, 60), linewidth = 1)
pBBLo  = plot(bbLoPlot,  "H1 BB Lower", color = color.new(color.orange, 60), linewidth = 1)
plot(bbMidPlot, "H1 BB Mid",   color = color.new(color.orange, 80), linewidth = 1, style = plot.style_cross)
fill(pBBUp, pBBLo, color = color.new(color.orange, 100), title = "BB Zone")

// ─────────────────────────────────────────────────────────────────────────────
// Previous Day High/Low (PDH/PDL)
// ─────────────────────────────────────────────────────────────────────────────

pPDH = plot(i_showPDHL ? pdH : na, "PDH", color = color.new(#42A5F5, 30), linewidth = 1, style = plot.style_stepline_diamond)
pPDL = plot(i_showPDHL ? pdL : na, "PDL", color = color.new(#42A5F5, 30), linewidth = 1, style = plot.style_stepline_diamond)

var label pdHLbl = na
var label pdLLbl = na
if barstate.islast and i_showPDHL
    if not na(pdHLbl)
        label.delete(pdHLbl)
    if not na(pdLLbl)
        label.delete(pdLLbl)
    pdHLbl := label.new(bar_index + 3, pdH, "PDH", style = label.style_none, textcolor = color.new(#42A5F5, 20), size = size.small)
    pdLLbl := label.new(bar_index + 3, pdL, "PDL", style = label.style_none, textcolor = color.new(#42A5F5, 20), size = size.small)

// ─────────────────────────────────────────────────────────────────────────────
// H1 FVG Detection (Fair Value Gap — 3-candle imbalance)
// ─────────────────────────────────────────────────────────────────────────────

var array<box> fvgBoxes = array.new<box>()
var array<float> fvgTops   = array.new<float>()
var array<float> fvgBots   = array.new<float>()
var array<int>   fvgDirs   = array.new<int>()

h1FvgBull = not na(h1L) and not na(h1PrevH2) and h1L > h1PrevH2
h1FvgBear = not na(h1H) and not na(h1PrevL2) and h1H < h1PrevL2

if h1BarNew and i_showFVG and timeframe.period == "60"
    if h1FvgBull
        _top = h1L
        _bot = h1PrevH2
        array.push(fvgTops, _top)
        array.push(fvgBots, _bot)
        array.push(fvgDirs, 1)
        _fvgBox = box.new(bar_index - 2, _top, bar_index, _bot,
             bgcolor = color.new(#00C853, 80), border_color = color.new(#00C853, 40), border_width = 2)
        box.set_text(_fvgBox, "FVG")
        box.set_text_color(_fvgBox, color.new(#00C853, 30))
        box.set_text_size(_fvgBox, size.small)
        array.push(fvgBoxes, _fvgBox)
    if h1FvgBear
        _top = h1PrevL2
        _bot = h1H
        array.push(fvgTops, _top)
        array.push(fvgBots, _bot)
        array.push(fvgDirs, -1)
        _fvgBox = box.new(bar_index - 2, _top, bar_index, _bot,
             bgcolor = color.new(#D50000, 80), border_color = color.new(#D50000, 40), border_width = 2)
        box.set_text(_fvgBox, "FVG")
        box.set_text_color(_fvgBox, color.new(#D50000, 30))
        box.set_text_size(_fvgBox, size.small)
        array.push(fvgBoxes, _fvgBox)
    while array.size(fvgBoxes) > i_fvgMaxBoxes
        box.delete(array.get(fvgBoxes, 0))
        array.remove(fvgBoxes, 0)
        array.remove(fvgTops, 0)
        array.remove(fvgBots, 0)
        array.remove(fvgDirs, 0)

if array.size(fvgBoxes) > 0
    _idx = array.size(fvgBoxes) - 1
    while _idx >= 0
        _ft = array.get(fvgTops, _idx)
        _fb = array.get(fvgBots, _idx)
        _fd = array.get(fvgDirs, _idx)
        _mitigated = h1BarNew and ((_fd == 1 and not na(h1C) and h1C < _fb) or (_fd == -1 and not na(h1C) and h1C > _ft))
        if _mitigated
            box.delete(array.get(fvgBoxes, _idx))
            array.remove(fvgBoxes, _idx)
            array.remove(fvgTops, _idx)
            array.remove(fvgBots, _idx)
            array.remove(fvgDirs, _idx)
        else
            box.set_right(array.get(fvgBoxes, _idx), bar_index + 5)
        _idx -= 1

// ─────────────────────────────────────────────────────────────────────────────
// H1 Order Block Detection (last opposing candle before FVG displacement)
// ─────────────────────────────────────────────────────────────────────────────

var array<box>   obBoxes = array.new<box>()
var array<float> obTops  = array.new<float>()
var array<float> obBots  = array.new<float>()
var array<int>   obDirs  = array.new<int>()

h1ObBull = h1FvgBull and not na(h1PrevBody1) and not na(h1AvgBody) and h1PrevBody1 > h1AvgBody * 1.5
     and not na(h1PrevC2) and not na(h1PrevO2) and h1PrevC2 < h1PrevO2
h1ObBear = h1FvgBear and not na(h1PrevBody1) and not na(h1AvgBody) and h1PrevBody1 > h1AvgBody * 1.5
     and not na(h1PrevC2) and not na(h1PrevO2) and h1PrevC2 > h1PrevO2

if h1BarNew and i_showOB and timeframe.period == "60"
    if h1ObBull
        _top = h1PrevH2
        _bot = h1PrevL2
        array.push(obTops, _top)
        array.push(obBots, _bot)
        array.push(obDirs, 1)
        _obBox = box.new(bar_index - 2, _top, bar_index, _bot,
             bgcolor = color.new(#00ACC1, 80), border_color = color.new(#00ACC1, 40), border_width = 2)
        box.set_text(_obBox, "OB")
        box.set_text_color(_obBox, color.new(#00ACC1, 20))
        box.set_text_size(_obBox, size.small)
        array.push(obBoxes, _obBox)
    if h1ObBear
        _top = h1PrevH2
        _bot = h1PrevL2
        array.push(obTops, _top)
        array.push(obBots, _bot)
        array.push(obDirs, -1)
        _obBox = box.new(bar_index - 2, _top, bar_index, _bot,
             bgcolor = color.new(#FF6D00, 80), border_color = color.new(#FF6D00, 40), border_width = 2)
        box.set_text(_obBox, "OB")
        box.set_text_color(_obBox, color.new(#FF6D00, 20))
        box.set_text_size(_obBox, size.small)
        array.push(obBoxes, _obBox)
    while array.size(obBoxes) > i_fvgMaxBoxes
        box.delete(array.get(obBoxes, 0))
        array.remove(obBoxes, 0)
        array.remove(obTops, 0)
        array.remove(obBots, 0)
        array.remove(obDirs, 0)

if array.size(obBoxes) > 0
    _idx = array.size(obBoxes) - 1
    while _idx >= 0
        _ot = array.get(obTops, _idx)
        _ob = array.get(obBots, _idx)
        _od = array.get(obDirs, _idx)
        _mitOb = h1BarNew and ((_od == 1 and not na(h1C) and h1C < _ob) or (_od == -1 and not na(h1C) and h1C > _ot))
        if _mitOb
            box.delete(array.get(obBoxes, _idx))
            array.remove(obBoxes, _idx)
            array.remove(obTops, _idx)
            array.remove(obBots, _idx)
            array.remove(obDirs, _idx)
        else
            box.set_right(array.get(obBoxes, _idx), bar_index + 5)
        _idx -= 1

// ─────────────────────────────────────────────────────────────────────────────
// PB Fib Zone — Fib lines + barcolor when price is in zone
// ─────────────────────────────────────────────────────────────────────────────

var line  _fibLine382 = na
var line  _fibLine618 = na
var line  _fibLine786 = na
var label _fibLbl     = na
var float _prevImpHi  = na
var float _prevImpLo  = na
var int   _prevZoneTr = 0
var float _pbFib382   = na
var float _pbFib618   = na
var float _pbFib786   = na
_impRange = not na(h1ImpHi) and not na(h1ImpLo) ? h1ImpHi - h1ImpLo : 0.0

var int    _alertConfCount = 0
var string _alertConfTxt   = ""

_pbZoneOk = i_showPbZone and timeframe.period == "60" and
     not na(h1ImpHi) and not na(h1ImpLo) and _impRange > 0 and h1Trend != 0

if _pbZoneOk
    _pbFib382 := h1Trend == 1 ? h1ImpHi - _impRange * 0.382 : h1ImpLo + _impRange * 0.382
    _pbFib618 := h1Trend == 1 ? h1ImpHi - _impRange * 0.618 : h1ImpLo + _impRange * 0.618
    _pbFib786 := h1Trend == 1 ? h1ImpHi - _impRange * 0.786 : h1ImpLo + _impRange * 0.786

    _swingChanged = h1ImpHi != _prevImpHi or h1ImpLo != _prevImpLo or h1Trend != _prevZoneTr

    _lineCol382 = color.new(h1Trend == 1 ? #00E676 : #FF5252, 60)
    _lineCol618 = color.new(h1Trend == 1 ? #00E676 : #FF5252, 30)
    _lineCol786 = color.new(h1Trend == 1 ? #00E676 : #FF5252, 40)

    if _swingChanged
        line.delete(_fibLine382)
        line.delete(_fibLine618)
        line.delete(_fibLine786)
        _fibLine382 := line.new(bar_index, _pbFib382, bar_index + 1, _pbFib382,
             color = _lineCol382, style = line.style_dotted, width = 1, extend = extend.right)
        _fibLine618 := line.new(bar_index, _pbFib618, bar_index + 1, _pbFib618,
             color = _lineCol618, style = line.style_dashed, width = 1, extend = extend.right)
        _fibLine786 := line.new(bar_index, _pbFib786, bar_index + 1, _pbFib786,
             color = _lineCol786, style = line.style_dotted, width = 1, extend = extend.right)
        _prevImpHi := h1ImpHi
        _prevImpLo := h1ImpLo
        _prevZoneTr := h1Trend

    // Confluence label at 61.8% line
    _fullTop = h1Trend == 1 ? _pbFib382 : _pbFib786
    _fullBtm = h1Trend == 1 ? _pbFib786 : _pbFib382
    _eInZ = not na(h1EmaF) and h1EmaF >= _fullBtm and h1EmaF <= _fullTop
    _fOvl = false
    if array.size(fvgTops) > 0
        for i = 0 to array.size(fvgTops) - 1
            if array.get(fvgTops, i) >= _fullBtm and array.get(fvgBots, i) <= _fullTop
                _fOvl := true
                break
    _pdH = not na(pdH) and pdH >= _fullBtm and pdH <= _fullTop
    _pdL = not na(pdL) and pdL >= _fullBtm and pdL <= _fullTop
    _kzOk = _londonActive or _nyActive

    _obOvl = false
    if array.size(obTops) > 0
        for i = 0 to array.size(obTops) - 1
            if array.get(obTops, i) >= _fullBtm and array.get(obBots, i) <= _fullTop
                _obOvl := true
                break

    _swpOk = not na(h1LastSweepBar) and (bar_index - h1LastSweepBar) <= 10
         and ((h1Trend == 1 and h1LastSweepDir == 1) or (h1Trend == -1 and h1LastSweepDir == -1))

    _confCount = 0
    _parts = ""
    if _eInZ
        _parts += "EMA "
        _confCount += 1
    if _fOvl
        _parts += "FVG "
        _confCount += 1
    if _obOvl
        _parts += "OB "
        _confCount += 1
    if _swpOk
        _parts += "SWP "
        _confCount += 1
    if _pdH
        _parts += "PDH "
        _confCount += 1
    if _pdL
        _parts += "PDL "
        _confCount += 1
    if _kzOk
        _parts += "KZ "
        _confCount += 1
    _confTxt = _parts != "" ? "OTE | " + str.trim(_parts) : "OTE"
    _alertConfCount := _confCount
    _alertConfTxt   := str.trim(_parts)

    label.delete(_fibLbl)
    _fibLbl := label.new(bar_index + 5, _pbFib618, _confTxt,
         style = label.style_label_left, color = color.new(color.black, 100),
         textcolor = color.new(h1Trend == 1 ? #00E676 : #FF5252, 20),
         size = size.small)
else
    _pbFib382 := na
    _pbFib618 := na
    _pbFib786 := na
    line.delete(_fibLine382)
    line.delete(_fibLine618)
    line.delete(_fibLine786)
    label.delete(_fibLbl)
    _fibLine382 := na
    _fibLine618 := na
    _fibLine786 := na
    _prevImpHi := na
    _prevImpLo := na
    _prevZoneTr := 0

_pbZoneTop = h1Trend == 1 ? _pbFib382 : _pbFib786
_pbZoneBtm = h1Trend == 1 ? _pbFib786 : _pbFib382
_inPbZone  = _pbZoneOk and not na(h1C) and not na(_pbZoneTop) and not na(_pbZoneBtm) and h1C >= _pbZoneBtm and h1C <= _pbZoneTop

_pbBarCol = _inPbZone ? color.new(h1Trend == 1 ? #00E676 : #FF5252, 0) : na

barcolor(_pbBarCol, title = "PB Fib Zone")

// ── Alert state tracking ──
var bool _wasInPbZone = false

_zoneEntry = _inPbZone and not _wasInPbZone
_wasInPbZone := _inPbZone
if not _inPbZone
    _alertConfCount := 0
    _alertConfTxt   := ""

// ─────────────────────────────────────────────────────────────────────────────
// Shared PB helpers (trend alignment, candle pattern, zone proximity, fib)
// ─────────────────────────────────────────────────────────────────────────────

h4TrendOk = h1Trend == 1 ? h4Trend != -1 : h1Trend == -1 ? h4Trend != 1 : true

h1AtrZone = not na(h1Atr) ? h1Atr * 1.5 : 0.0

h1PendGreen  = not na(h1C) and not na(h1PrevC1) and h1C > h1PrevC1
h1PendRed    = not na(h1C) and not na(h1PrevC1) and h1C < h1PrevC1
h1PendDown1  = not na(h1PrevC1) and not na(h1PrevC2) and h1PrevC1 < h1PrevC2
h1PendDown2  = h1PendDown1 and not na(h1PrevC3) and h1PrevC2 < h1PrevC3
h1PendUp1    = not na(h1PrevC1) and not na(h1PrevC2) and h1PrevC1 > h1PrevC2
h1PendUp2    = h1PendUp1 and not na(h1PrevC3) and h1PrevC2 > h1PrevC3
h1PendPbDnOk = i_pbBars >= 2 ? h1PendDown2 : h1PendDown1
h1PendPbUpOk = i_pbBars >= 2 ? h1PendUp2   : h1PendUp1

h1PendNearSwLo = not na(h1L) and not na(h1LastSwLo) and h1L <= h1LastSwLo + h1AtrZone
h1PendNearSwHi = not na(h1H) and not na(h1LastSwHi) and h1H >= h1LastSwHi - h1AtrZone
h1PendNearEma  = not na(h1L) and not na(h1H) and not na(h1EmaF) and
     (h1L <= h1EmaF + h1AtrZone and h1H >= h1EmaF - h1AtrZone)

// FVG zone check — is price inside an active (unmitigated) FVG?
var bool _inBullFvg = false
var bool _inBearFvg = false
_inBullFvg := false
_inBearFvg := false
if array.size(fvgTops) > 0
    for i = array.size(fvgTops) - 1 to 0
        _ft = array.get(fvgTops, i)
        _fb = array.get(fvgBots, i)
        _fd = array.get(fvgDirs, i)
        if _fd == 1 and not na(h1L) and h1L <= _ft and h1L >= _fb
            _inBullFvg := true
        if _fd == -1 and not na(h1H) and h1H >= _fb and h1H <= _ft
            _inBearFvg := true

h1PendZoneBull = h1PendNearSwLo or h1PendNearEma or _inBullFvg
h1PendZoneBear = h1PendNearSwHi or h1PendNearEma or _inBearFvg

// ─────────────────────────────────────────────────────────────────────────────
// Phase 2: Pattern Ready — reversal candle appeared in zone
// ─────────────────────────────────────────────────────────────────────────────

_dotLvl   = h1PendGreen ? h1L : h1PendRed ? h1H : na
_dotDepth = _impRange > 0 and not na(_dotLvl) ?
     (h1PendGreen ? (h1ImpHi - _dotLvl) / _impRange : (_dotLvl - h1ImpLo) / _impRange) * 100 : na
_dotFibOk = not na(_dotDepth) and _dotDepth >= 38.2 and _dotDepth <= 100.0

h1DotBull = i_pbH1 and timeframe.period == "60" and h1Trend == 1  and h4TrendOk and h1PendPbDnOk and h1PendGreen and h1PendZoneBull and _dotFibOk
h1DotBear = i_pbH1 and timeframe.period == "60" and h1Trend == -1 and h4TrendOk and h1PendPbUpOk and h1PendRed   and h1PendZoneBear and _dotFibOk

plotshape(i_showPbDots and h1DotBull, style = shape.triangleup, size = size.tiny,
     color = color.new(#00E676, 0), location = location.belowbar, title = "PB Dot Bull")
plotshape(i_showPbDots and h1DotBear, style = shape.triangledown, size = size.tiny,
     color = color.new(#FF5252, 0), location = location.abovebar, title = "PB Dot Bear")

// ─────────────────────────────────────────────────────────────────────────────
// Alert System (3-Tier)
// ─────────────────────────────────────────────────────────────────────────────

_alertDir = h1Trend == 1 ? "BULL" : h1Trend == -1 ? "BEAR" : "FLAT"

// Tier 1: Price enters Fib zone (first bar only)
_t1Bull = _zoneEntry and h1Trend == 1
_t1Bear = _zoneEntry and h1Trend == -1
alertcondition(_t1Bull, title = "🟡 T1 Zone Entry Bull",
     message = '{"tier":1,"type":"ZONE_ENTRY","dir":"BULL","pair":"{{ticker}}","tf":"H1","price":"{{close}}","action":"เตรียมตัว — ราคาเข้าโซน Fib"}')
alertcondition(_t1Bear, title = "🟡 T1 Zone Entry Bear",
     message = '{"tier":1,"type":"ZONE_ENTRY","dir":"BEAR","pair":"{{ticker}}","tf":"H1","price":"{{close}}","action":"เตรียมตัว — ราคาเข้าโซน Fib"}')

// Tier 2: High confluence (>= 3 factors) while in zone
_t2Bull = _inPbZone and h1Trend == 1  and _alertConfCount >= 3
_t2Bear = _inPbZone and h1Trend == -1 and _alertConfCount >= 3
alertcondition(_t2Bull, title = "🟠 T2 High Confluence Bull",
     message = '{"tier":2,"type":"HIGH_CONF","dir":"BULL","pair":"{{ticker}}","tf":"H1","price":"{{close}}","action":"โอกาสดี — confluence สูง เริ่มหา entry"}')
alertcondition(_t2Bear, title = "🟠 T2 High Confluence Bear",
     message = '{"tier":2,"type":"HIGH_CONF","dir":"BEAR","pair":"{{ticker}}","tf":"H1","price":"{{close}}","action":"โอกาสดี — confluence สูง เริ่มหา entry"}')

// Tier 3a: Sweep in zone (aligned with trend)
_sweepInZoneBull = h1SweepBull and _inPbZone and h1Trend == 1
_sweepInZoneBear = h1SweepBear and _inPbZone and h1Trend == -1
alertcondition(_sweepInZoneBull, title = "🔴 T3 Sweep+Zone Bull",
     message = '{"tier":3,"type":"SWEEP_ZONE","dir":"BULL","pair":"{{ticker}}","tf":"H1","price":"{{close}}","action":"พร้อม — Sweep ในโซน OTE เตรียม entry Long"}')
alertcondition(_sweepInZoneBear, title = "🔴 T3 Sweep+Zone Bear",
     message = '{"tier":3,"type":"SWEEP_ZONE","dir":"BEAR","pair":"{{ticker}}","tf":"H1","price":"{{close}}","action":"พร้อม — Sweep ในโซน OTE เตรียม entry Short"}')

// Tier 3b: Phase 2 confirmation (existing)
alertcondition(h1DotBull, title = "🔴 T3 PB Confirm Bull",
     message = '{"tier":3,"type":"PB_CONFIRM","dir":"BULL","pair":"{{ticker}}","tf":"H1","price":"{{close}}","action":"พร้อม — แท่งกลับตัวยืนยัน เตรียม entry Long"}')
alertcondition(h1DotBear, title = "🔴 T3 PB Confirm Bear",
     message = '{"tier":3,"type":"PB_CONFIRM","dir":"BEAR","pair":"{{ticker}}","tf":"H1","price":"{{close}}","action":"พร้อม — แท่งกลับตัวยืนยัน เตรียม entry Short"}')

// ─────────────────────────────────────────────────────────────────────────────
// M15 Momentum Candle
// ─────────────────────────────────────────────────────────────────────────────

m15Bull = m15C > m15O
m15SuperBody   = not na(m15Body) and not na(m15AvgB) and m15Body > m15AvgB * i_momSuper
m15AboveAvg    = not na(m15Body) and not na(m15AvgB) and m15Body > m15AvgB
m15Mom = m15SuperBody ? (m15Bull ? 2 : -2) : m15AboveAvg ? (m15Bull ? 1 : -1) : 0

aboveAvgBullClr = color.new(#66BB6A, 0)
superBullClr    = color.new(#1B5E20, 0)
aboveAvgBearClr = color.new(#EF5350, 0)
superBearClr    = color.new(#B71C1C, 0)

m15MomCol = not i_showMomBar or not isM15 ? na :
     m15Mom ==  2 ? superBullClr :
     m15Mom == -2 ? superBearClr :
     m15Mom ==  1 ? aboveAvgBullClr :
     m15Mom == -1 ? aboveAvgBearClr : na

barcolor(m15MomCol, title = "M15 Momentum")
